    {
      "type": "range",
      "id": "trigger-close-delay",
      "label": "t:sections.overlay-group.all.settings.trigger-close-delay.label",
      "min": 1,
      "max": 100,
      "unit": "sec",
      "default": 30,
      "visible_if": "{{ section.settings.trigger-close == 'delay' }}"
    },
    {
      "type": "select",
      "id": "close-scroll-type",
