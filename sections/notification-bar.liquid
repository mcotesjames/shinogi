      "info": "t:sections.overlay-group.all.settings.advanced.f4-close.info",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "limit": 1,
      "name": "t:sections.overlay-group.notification-bar.blocks.heading.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "t:sections.overlay-group.notification-bar.blocks.heading.settings.heading.label",
          "default": "t:sections.overlay-group.notification-bar.blocks.heading.settings.heading.default"
