      "min": 0,
      "max": 100,
      "unit": "sec",
      "default": 1,
      "visible_if": "{{ section.settings.trigger-open == 'delay' }}"
    },
    {
      "type": "select",
      "id": "open-scroll-type",
      "options": [
        {
          "value": "px",
