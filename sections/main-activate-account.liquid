{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}

<div class="customer activate">
  <div class="container customer-container">
    <div class="activate__outer">
      <div class="page-header">
        <div class="page-header__inner">
          <h1 class="main-page-title page-title title--page h6">
            {{- 'customer.activate_account.title' | t -}}
          </h1>
          <p class="activate__subtitle">
            {{- 'customer.activate_account.subtext' | t -}}
          </p>
        </div>
      </div>

      {%- form 'activate_customer_password' -%}
        <div class="field">
          <input
            type="password"
            name="customer[password]"
            id="password"
            dir="ltr"
            required
            autocomplete="new-password"
            placeholder="{{ 'customer.activate_account.password' | t }}"
            {% if form.errors contains 'password' %}
              aria-invalid="true" aria-describedby="password-error"
            {% endif %}
          >
          <label for="password">
            {{ 'customer.activate_account.password' | t }}
          </label>
        </div>
        {%- if form.errors contains 'password' -%}
          <small id="password-error" class="form__message form__message--error">
            {{ form.errors.translated_fields.password | capitalize }}
            {{ form.errors.messages.password }}
          </small>
        {%- endif -%}

        <div class="field">
          <input
            type="password"
            name="customer[password_confirmation]"
            id="password_confirmation"
            dir="ltr"
            required
            autocomplete="new-password"
            placeholder="{{ 'customer.activate_account.password_confirm' | t }}"
            {% if form.errors contains 'password' %}
              aria-invalid="true" aria-describedby="password_confirmation-error"
            {% endif %}
          >
          <label for="password_confirmation">
            {{ 'customer.activate_account.password_confirm' | t }}
          </label>
        </div>
        {%- if form.errors contains 'password_confirmation' -%}
          <small id="password_confirmation-error" class="form__message form__message--error">
            {{ form.errors.translated_fields.password_confirmation | capitalize }}
            {{ form.errors.messages.password_confirmation }}
          </small>
        {%- endif -%}

        <div class="activate__buttons">
          <button class="button button--primary focus-inset">
            <div class="button__content">
              <span class="button__label" data-label="{{- 'customer.activate_account.submit' | t -}}">
                {{- 'customer.activate_account.submit' | t -}}
              </span>
            </div>
          </button>
          <button name="decline" class="button button--tertiary focus-inset">
            <span>{{- 'customer.activate_account.cancel' | t -}}</span>
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-activate-account.name"
}
{% endschema %}
