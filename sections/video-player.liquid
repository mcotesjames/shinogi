<script type="module" src="https://cdn.jsdelivr.net/npm/@videojs/html/cdn/video-minimal.js"></script>
{{ 'video-player-skin.css' | asset_url | stylesheet_tag }}
{{ 'section-video-player.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

<div id="video-player" class="video-player-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} background{% if section.settings.enable_border_top %} section-border-top{% endif %}{% if section.settings.enable_border_bottom %} section-border-bottom{% endif %}">
  <div class="video-with-text{% if section.settings.columns == '1' %} video-with-text--single{% elsif section.settings.reverse_columns %} video-with-text--reversed{% endif %}">

    <div class="video-with-text__text">
      {%- if section.settings.eyebrow != blank -%}
        <p class="video-with-text__eyebrow subtitle">{{- section.settings.eyebrow -}}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag | default: 'h2' }} class="video-with-text__heading {{ section.settings.heading_size | default: 'h2' }} richtext-link-inside">
          {{- section.settings.heading -}}
        </{{ section.settings.heading_tag | default: 'h2' }}>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="video-with-text__description rte richtext-link-inside">
          {{- section.settings.description -}}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <div class="video-with-text__btn-wrapper">
          {% render 'button',
            btn_label: section.settings.button_label,
            btn_link: section.settings.button_link,
            btn_style: section.settings.button_style
          %}
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="video-timestamps">
          {%- for block in section.blocks -%}
            <li class="video-timestamps__item" {{ block.shopify_attributes }}>
              <a href="#" class="video-timestamps__link h6" data-timestamp="{{ block.settings.timestamp }}">
                {{- block.settings.label -}}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="video-with-text__video">
      {%- if section.settings.video_url != blank -%}
        <div class="video-player-wrapper"{% if section.settings.columns == '1' %} style="--video-aspect-ratio: {{ section.settings.aspect_ratio | default: '1.7778' }}"{% endif %}>
          <video-player>
            <video-minimal-skin>
              <video
                src="{{ section.settings.video_url }}"
                {% if section.settings.autoplay %}autoplay muted{% endif %}
                {% if section.settings.loop %}loop{% endif %}
                {% if section.settings.poster_image != blank %}poster="{{ section.settings.poster_image | image_url: width: 1920 }}"{% endif %}
                preload="{{ section.settings.preload | default: 'auto' }}"
                playsinline
              ></video>
            </video-minimal-skin>
          </video-player>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Video Player",
  "tag": "section",
  "class": "video-player-section-wrapper",
  "blocks": [
    {
      "type": "timestamp",
      "name": "Timestamp",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Chapter title"
        },
        {
          "type": "text",
          "id": "timestamp",
          "label": "Timestamp",
          "info": "Format: 0:00",
          "default": "0:00"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "Link to a .mp4, .m4v, or .webm file"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false,
      "info": "Autoplayed videos are always muted"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": false
    },
    {
      "type": "select",
      "id": "preload",
      "label": "Preload",
      "info": "Controls how much the browser buffers before playback. 'Auto' begins downloading immediately for the best experience on slow connections.",
      "options": [
        { "value": "auto", "label": "Auto (recommended)" },
        { "value": "metadata", "label": "Metadata only" },
        { "value": "none", "label": "None" }
      ],
      "default": "auto"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image",
      "info": "Shown while the video is loading. Improves perceived performance on slow connections."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.heading_size.label",
      "options": [
        { "value": "h6", "label": "t:sections.all.heading_size.options__6.label" },
        { "value": "h5", "label": "t:sections.all.heading_size.options__5.label" },
        { "value": "h4", "label": "t:sections.all.heading_size.options__4.label" },
        { "value": "h3", "label": "t:sections.all.heading_size.options__3.label" },
        { "value": "h2", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__1.label" }
      ],
      "default": "h2",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.all.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.all.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.all.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.all.heading_tag.options__4.label" },
        { "value": "h5", "label": "t:sections.all.heading_tag.options__5.label" },
        { "value": "h6", "label": "t:sections.all.heading_tag.options__6.label" },
        { "value": "div", "label": "t:sections.all.heading_tag.options__7.label" }
      ],
      "default": "h2",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "checkbox",
      "id": "heading_group_button_show",
      "label": "t:sections.all.button.button_show.label",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.all.button.button_label.label",
      "visible_if": "{{ section.settings.heading_group_button_show == true }}"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button.button_link.label",
      "visible_if": "{{ section.settings.heading_group_button_show == true }}"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.all.button.button_style.label",
      "options": [
        { "value": "primary", "label": "t:sections.all.button.button_style.options__1.label" },
        { "value": "secondary", "label": "t:sections.all.button.button_style.options__2.label" },
        { "value": "tertiary", "label": "t:sections.all.button.button_style.options__3.label" }
      ],
      "default": "tertiary",
      "visible_if": "{{ section.settings.heading_group_button_show == true }}"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "1", "label": "1 column" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "1.7778", "label": "16:9" },
        { "value": "2.3333", "label": "21:9" },
        { "value": "1.3333", "label": "4:3" },
        { "value": "1", "label": "1:1" }
      ],
      "default": "1.7778",
      "visible_if": "{{ section.settings.columns == '1' }}"
    },
    {
      "type": "checkbox",
      "id": "reverse_columns",
      "label": "Video on left",
      "default": false,
      "visible_if": "{{ section.settings.columns == '2' }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "enable_border_top",
      "default": false,
      "label": "t:sections.all.borders.enable_border_top.label"
    },
    {
      "type": "checkbox",
      "id": "enable_border_bottom",
      "default": false,
      "label": "t:sections.all.borders.enable_border_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-padding.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-padding.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-padding.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-padding.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-padding.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-padding.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        { "value": "no-indent", "label": "t:sections.all.section-margin.options__1.label" },
        { "value": "xs", "label": "t:sections.all.section-margin.options__2.label" },
        { "value": "s", "label": "t:sections.all.section-margin.options__3.label" },
        { "value": "m", "label": "t:sections.all.section-margin.options__4.label" },
        { "value": "l", "label": "t:sections.all.section-margin.options__5.label" },
        { "value": "xl", "label": "t:sections.all.section-margin.options__6.label" }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "Video Player",
      "category": "t:sections.categories.media"
    }
  ]
}
{% endschema %}
