            }
          ],
          "default": "cover",
          "label": "t:sections.all.card.image_fit.label"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 0,
          "unit": "%",
          "label": "t:sections.all.overlay_opacity.label"
        },
        {
          "type": "checkbox",
          "id": "image_as_link",
          "label": "t:sections.collapsible-content.blocks.accordion.settings.image_as_link.label",
          "default": false
        },
        {
          "type": "url",
          "id": "image_link",
          "label": "t:sections.collapsible-content.blocks.accordion.settings.image_link.label",
          "visible_if": "{{ block.settings.image_as_link == true }}"
        }
      ]
