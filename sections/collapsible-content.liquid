{{ 'section-collapsible-content.css' | asset_url | stylesheet_tag }}

<script src="{{ 'collapsible-content.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

{% liquid
  if section.settings.aspect_ratio == 'landscape'
    assign padding_bottom = '69.5'
  elsif section.settings.aspect_ratio == 'portrait'
    assign padding_bottom = '131.6'
  elsif section.settings.aspect_ratio == 'recommended'
    assign padding_bottom = '80'
  elsif section.settings.aspect_ratio == 'square'
    assign padding_bottom = '100'
  elsif section.settings.aspect_ratio == 'adapt-to-content'
    assign padding_bottom = '0'
  endif
%}

{% liquid
  if section.settings.aspect_ratio_mobile == 'landscape'
    assign padding_bottom_mobile = '69.5'
  elsif section.settings.aspect_ratio_mobile == 'portrait'
    assign padding_bottom_mobile = '131.6'
  elsif section.settings.aspect_ratio_mobile == 'recommended'
    assign padding_bottom_mobile = '80'
  elsif section.settings.aspect_ratio_mobile == 'square'
    assign padding_bottom_mobile = '100'
  else
    assign padding_bottom_mobile = '0'
  endif
%}

{%- style -%}
  .collapsible-content-{{ section.id }} .collapsible-content__media::before {
    content: '';
    display: block;
    width: 0;
    padding-bottom: {{ padding_bottom_mobile }}%;
  }

  @media  (min-width: 990px){
    .collapsible-content-{{ section.id }} .collapsible-content__media::before {
      content: '';
      display: block;
      width: 0;
      padding-bottom: {{ padding_bottom }}%;
    }
  }
{%- endstyle -%}

<div
  class="
    collapsible-content collapsible-content-{{ section.id }} color-{{ section.settings.color_scheme }} background  section-{{ section.id }}-padding
    {% if section.settings.enable_border_top %} section-border-top{% endif %}{% if section.settings.enable_border_bottom %} section-border-bottom{% endif %}
  "
  data-enable-autoplay="{{ section.settings.enable_autoplay }}"
  {% if section.settings.enable_autoplay %}
    data-autoplay-speed="{{ section.settings.slider_speed }}"
    data-stop-on-hover="{{ section.settings.enable_stop_on_hover }}"
    data-enable-loop="{{ section.settings.enable_loop }}"
  {% endif %}
>
  {% render 'heading-group', settings: section.settings, class: 'collapsible-content-header' %}

  <div class="collapsible-content__content order--{{section.settings.objects_order_desktop }} order-mobile--{{section.settings.objects_order_mobile}}">
    <div class="collapsible-content__items">
      {%- for block in section.blocks -%}
        <div
          class="
            collapsible-content__item {% if forloop.index == 1 %} active{% endif %}
            color-{{ block.settings.row_color_scheme }} horizontal-align--{{ block.settings.text_alignment }}
          "
          role="button"
          tabindex="0"
          data-index-content="{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.question != blank -%}
            <{{ block.settings.content_heading_tag | default: 'h3' }}
              class="collapsible-content__question {{ block.settings.content_heading_size}} richtext-link-inside"
            >
              {{ block.settings.question | escape }}
            </{{ block.settings.content_heading_tag | default: 'h3' }}>
          {%- endif -%}
          {% liquid
            assign display_button = false
            if block.settings.list_button_show and block.settings.list_button_label != blank
              assign display_button = true
            endif
          %}
          {%- if block.settings.answer != blank or display_button == true -%}
            <div class="collapsible-content__answer">
              <div class="collapsible-content__answer-wrapper">
                <div class="collapsible-content__answer-description rte">
                  {{ block.settings.answer }}
                </div>

                {%- if block.settings.list_button_show == true and block.settings.list_button_label != blank -%}
                  {% render 'button',
                    btn_label: block.settings.list_button_label,
                    btn_style: block.settings.list_button_style,
                    btn_link: block.settings.list_button_url,
                    class: 'collapsible-content__btn'
                  %}
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {% if section.settings.enable_autoplay %}
            <div class="collapsible-content__progress"></div>
          {% endif %}
        </div>
      {%- endfor -%}
    </div>
    <div class="collapsible-content__media">
      {%- for block in section.blocks -%}
        {% liquid
          if block.settings.image
            assign image = block.settings.image
          else
            assign image = blank
          endif
        %}
        <div
          class="collapsible-content__image-wrapper {% if forloop.index == 1 %} active{% endif %}"
          data-index-media="{{ forloop.index }}"
          {{ block.shopify_attributes }}
        >
          {%- if image != blank -%}
            {% comment %} Image settings {% endcomment %}

            {% liquid
              assign image_styles = 'object-fit: ' | append: block.settings.object_fit

              if section.settings.aspect_ratio == 'adapt-to-content'
                assign settings_aspect_ratio = 1
              else
                if section.settings.aspect_ratio == 'landscape'
                  assign settings_aspect_ratio = 1.44
                elsif section.settings.aspect_ratio == 'portrait'
                  assign settings_aspect_ratio = 0.76
                elsif section.settings.aspect_ratio == 'recommended'
                  assign settings_aspect_ratio = 1.26
                else
                  assign settings_aspect_ratio = 1
                endif
              endif

              assign calc_ratio_desktop = 1

              if image.aspect_ratio > settings_aspect_ratio
                assign calc_ratio_desktop = image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
              endif

              if section.settings.aspect_ratio_mobile == 'adapt-to-content'
                assign settings_aspect_ratio_mobile = 1
              else
                if section.settings.aspect_ratio_mobile == 'landscape'
                  assign settings_aspect_ratio_mobile = 1.44
                elsif section.settings.aspect_ratio_mobile == 'portrait'
                  assign settings_aspect_ratio_mobile = 0.76
                elsif section.settings.aspect_ratio_mobile == 'recommended'
                  assign settings_aspect_ratio_mobile = 1.26
                else
                  assign settings_aspect_ratio_mobile = 1
                endif
              endif

              assign calc_ratio_mobile = 1

              if image.aspect_ratio > settings_aspect_ratio
                assign calc_ratio_mobile = image.aspect_ratio | divided_by: settings_aspect_ratio_mobile | round: 2
              endif

              assign image_loading = 'lazy'

              if section.index == 1
                assign image_loading = 'eager'
              endif
            %}
            {%- capture image_sizes -%}
              (min-width: 990px) calc(50vw * {{ calc_ratio_desktop }}), calc(100vw * {{ calc_ratio_mobile }})
            {%- endcapture -%}

            {{
              image
              | image_url: width: image.width
              | image_tag:
                width: image.width,
                height: image.height,
                widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                sizes: image_sizes,
                class: 'collapsible-content__image',
                style: image_styles,
                loading: image_loading
            }}
          {% else %}
            {%- liquid
              assign placeholder_class = 'placeholder-svg collapsible-content__placeholder'

              if section.settings.aspect_ratio == 'adapt-to-content'
                assign placeholder_class = placeholder_class | append: ' ' | append: 'adapt-to-content'
              endif

              assign index = forloop.index | modulo: 3 | plus: 1
            %}
            {{ 'hero-apparel-' | append: index | placeholder_svg_tag: placeholder_class }}
          {%- endif -%}

          {% comment %} Image as link {% endcomment %}
          {% if block.settings.image_as_link != false and block.settings.image_link != blank %}
            <a
              class="collapsible-content__image-link"
              href="{{ block.settings.image_link_url }}"
              target="{{ block.settings.image_link_target }}"
            ></a>
          {% endif %}
          {% comment %} Overlay {% endcomment %}
          {% if block.settings.overlay_opacity != 0 %}
            <span
              class="collapsible-content__overlay"
              style="opacity: {{ block.settings.overlay_opacity | times: 0.01 }};"
            ></span>
          {% endif %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.collapsible-content.name",
  "tag": "section",
  "class": "collapsible-content-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "blocks": [
    {
      "type": "accordion",
      "name": "t:sections.collapsible-content.blocks.accordion.name",
      "limit": 20,
      "settings": [
        {
          "type": "color_scheme",
          "id": "row_color_scheme",
          "default": "background-1",
          "label": "t:sections.collapsible-content.settings.row_color_scheme.label"
        },
        {
          "type": "header",
