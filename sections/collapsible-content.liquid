        {
          "value": "content_first",
          "label": "t:sections.collapsible-content.settings.objects_order.options__1.label"
        },
        {
          "value": "image_first",
          "label": "t:sections.collapsible-content.settings.objects_order.options__2.label"
        }
      ],

      "default": "content_first"
    },
    {
      "type": "select",
      "id": "objects_order_mobile",
      "label": "t:sections.collapsible-content.settings.objects_order_mobile.label",
