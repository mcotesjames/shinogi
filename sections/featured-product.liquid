{{ 'section-featured-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'featured-product.js' | asset_url }}" defer="defer"></script>
{%- for block in section.blocks -%}
  {%- if block.type == 'share' -%}
    <script src="{{ 'copy.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endfor -%}

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

{%- assign featured_product = section.settings.product_item -%}
{%- assign first_3d_model = featured_product.media | where: 'media_type', 'model' | first -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
  <link
    id="ModelViewerStyle"
    rel="stylesheet"
    href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
    media="print"
    onload="this.media='all'"
  >
  <link
    id="ModelViewerOverride"
    rel="stylesheet"
    href="{{ 'component-model-viewer-ui.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
{%- endif -%}

<div class="featured-product color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding{% if section.settings.enable_border_top %} section-border-top{% endif %}{% if section.settings.enable_border_bottom %} section-border-bottom{% endif %}{% if section.settings.enable_equal_columns %} featured-product--equal-columns{% endif %}">
  {% render 'heading-group', settings: section.settings, class: 'featured-product-header' %}
  <div class="product">
    <div class="product__outer">
      {%- if section.settings.show_no_media_placeholder or featured_product.media.size > 0 -%}
        {% liquid
          assign featured_product_media_size = featured_product.media.size
          if featured_product == blank
            assign featured_product_media_size = 3
          endif
        %}
        <div
          class="product__media product__media--size-{{ featured_product_media_size }} product__media--desktop-type-slider product__media--mobile-type-slider product__media--desktop-ratio-{{ section.settings.desktop_media_ratio }} {% if section.settings.desktop_gallery_order == 'after' %} product__media--desktop-after{% endif %}{% if section.settings.mobile_gallery_order == 'after' %} product__media--mobile-after{% endif %}{% if featured_product_media_size == 0 %} product__media--no-media{% endif %}"
          data-section="product-media-{{ section.id }}"
        >
          <div class="product__media-wrapper">
            {% liquid
              assign has_slider_classes = false
              if featured_product.media.size > 1 or featured_product == blank
                assign has_slider_classes = true
              endif
            %}
            <div class="product__media-list-wrapper">
              <div
                class="product__media-list{% if has_slider_classes %} js-media-list swiper {% if section.settings.enable_border_between_images%} product__media-list--with-borders{% endif %}{% endif %}"
                data-desktop-type="slider"
                data-mobile-type="slider"
                data-has-desktop-zoom="false"
                data-has-mobile-zoom="false"
              >
                <div class="product__media-list-container{% if has_slider_classes %} swiper-wrapper{% endif %}">
                  {%- if featured_product.media.size > 0 -%}
                    {%- if featured_product.selected_or_first_available_variant.featured_media != null -%}
                      {%- assign featured_media = featured_product.selected_or_first_available_variant.featured_media -%}

                      <div
                        class="product__media-item{% if has_slider_classes %} swiper-slide{% endif %}"
                        data-media-id="{{ section.id }}-{{ featured_media.id }}"
                      >
                        {% render 'product-media-item',
                          media: featured_media,
                          product_obj: featured_product,
                          section_obj: section,
                          is_featured: true
                        %}
                      </div>
                    {%- endif -%}

                    {%- for media in featured_product.media -%}
                      {%- if media.id != featured_media.id -%}
                        <div
                          class="product__media-item{% if has_slider_classes %} swiper-slide{% endif %}"
                          data-media-id="{{ section.id }}-{{ media.id }}"
                        >
                          {% render 'product-media-item',
                            media: media,
                            product_obj: featured_product,
                            section_obj: section
                          %}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  {% else %}
                    {%- if featured_product != blank -%}
                      <div class="product__media-item product__media-item--placeholder">
                        {% render 'product-media-item', product_obj: featured_product, section_obj: section %}
                      </div>
                    {%- else -%}
                      {%- for featured_product_placeholder_index in (1..3) -%}
                        <div class="product__media-item product__media-item--placeholder{% if has_slider_classes %} swiper-slide{% endif %}">
                          {% render 'product-media-item',
                            product_obj: featured_product,
                            section_obj: section,
                            is_featured_product_placeholder: true,
                            featured_product_placeholder_index: featured_product_placeholder_index
                          %}
                        </div>
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endif -%}
                </div>

                {%- if has_slider_classes -%}
                  <div class="container product__slider-nav no-js-hidden">
                    <button class="swiper-button-prev product__slider-nav-prev focus-inset">
                      <div class="product__slider-nav-icons-container product__slider-nav-icons-container--prev">
                        {% render 'icon-arrow-left-product' %}
                        {% render 'icon-arrow-left-product' %}
                      </div>
                    </button>
                    <button class="swiper-button-next product__slider-nav-next focus-inset">
                      <div class="product__slider-nav-icons-container product__slider-nav-icons-container--next">
                        {% render 'icon-arrow-right-product' %}
                        {% render 'icon-arrow-right-product' %}
                      </div>
                    </button>
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}

      <div id="ProductInfo-{{ section.id }}" data-section="{{ section.id }}" class="product__info-container">
        {%- assign product_form_id = 'product-form-' | append: section.id -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'text' -%}
              {% render 'product-block-text', product: featured_product, block_obj: block %}

            {%- when 'title' -%}
              {%- if featured_product != blank -%}
                {% render 'product-block-title', product: featured_product, block_obj: block, with_link: true %}
              {%- else -%}
                {% comment %} PLACEHOLDER WHEN NO PRODUCT IS SELECTED {% endcomment %}
                <{{ block.settings.heading_tag }} class="product__title {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                  {{- 'products.product.title_placeholder' | t -}}
                </{{ block.settings.heading_tag }}>
              {%- endif -%}

            {%- when 'tags' -%}
              {%- if featured_product != blank -%}
                {% render 'product-block-tags', product: featured_product, block_obj: block %}
              {%- else -%}
                {% comment %} PLACEHOLDER WHEN NO PRODUCT IS SELECTED {% endcomment %}
                {%- assign tags_placeholder = 'products.product.tags_placeholder' | t | split: ', ' -%}
                <div class="product__badges body-small" {{ block.shopify_attributes }}>
                  {%- for tag_placeholder in tags_placeholder -%}
                    <span class="badge badge--custom">{{- tag_placeholder -}}</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}

            {%- when 'badges' -%}
              {%- if featured_product != blank -%}
                {% render 'product-block-badges', product: featured_product, block_obj: block %}
              {%- endif -%}

            {%- when 'price' -%}
              {% render 'product-block-price', product: featured_product, block_obj: block, section_id: section.id %}

            {%- when 'description' -%}
              {%- if featured_product != blank -%}
                {% render 'product-block-description', product: featured_product, block_obj: block %}
              {%- else -%}
                {% comment %} PLACEHOLDER WHEN NO PRODUCT IS SELECTED {% endcomment %}
                {%- assign placeholder_description = 'products.product.description_placeholder' | t -%}
                {% render 'product-block-description',
                  product: featured_product,
                  block_obj: block,
                  placeholder_text: placeholder_description
                %}
              {%- endif -%}

            {%- when 'sku' -%}
              {%- if featured_product != blank -%}
                {% render 'product-block-sku', product: featured_product, block_obj: block, section_id: section.id %}
              {%- endif -%}

            {%- when 'inventory' -%}
              {%- if featured_product != blank -%}
                {% render 'product-block-inventory',
                  product: featured_product,
                  section_obj: section,
                  block_obj: block
                %}
              {%- else -%}
                {% comment %} PLACEHOLDER WHEN NO PRODUCT IS SELECTED {% endcomment %}
                <div class="product__inventory body-small" role="status" {{ block.shopify_attributes }}>
                  <span class="subtitle product__inventory-inner product__inventory-inner--out-of-stock">
                    {{- 'products.product.inventory_out_of_stock' | t -}}
                  </span>
                </div>
              {%- endif -%}

            {%- when 'variant_picker' -%}
              {%- if featured_product != blank -%}
                {% render 'product-variant-picker',
                  product: featured_product,
                  section_obj: section,
                  block_obj: block,
                  section_id: section.id,
                  product_form_id: product_form_id,
                  need_update_page_url: false
                %}
              {%- else -%}
                {% comment %} PLACEHOLDER WHEN NO PRODUCT IS SELECTED {% endcomment %}
                {% render 'product-variant-picker-placeholder', block: block %}
              {%- endif -%}

            {%- when 'buy_buttons' -%}
              {%- if featured_product != blank -%}
                {% render 'product-buy-buttons',
                  product: featured_product,
                  section_obj: section,
                  block_obj: block,
                  section_id: section.id,
                  product_form_id: product_form_id
                %}
              {%- else -%}
                {% comment %} PLACEHOLDER WHEN NO PRODUCT IS SELECTED {% endcomment %}
                {% render 'product-buy-buttons-placeholder', block: block %}
              {%- endif -%}

            {%- when 'share' -%}
              {% render 'product-block-share', product: featured_product, block_obj: block %}

            {%- when 'popup' -%}
              {% render 'product-block-popup',
                block_id: block.id,
                block_attributes: block.shopify_attributes,
                popup_label: block.settings.label,
                popup_color_scheme: block.settings.color_scheme,
                popup_content_heading: block.settings.heading,
                popup_content_text: block.settings.text,
                popup_page_content: block.settings.page.content,
                class: 'featured-product-popup-modal'
              %}

            {%- when 'collapsible_info' -%}
              {% render 'product-block-collapsible-info', block_obj: block %}

            {%- when 'icon_with_text' -%}
              {% render 'product-block-icon-with-text', block_obj: block %}

            {%- when 'divider' -%}
              {% render 'product-block-divider', block_obj: block %}

            {%- when 'custom_liquid' -%}
              <div class="custom-liquid" {{ block.shopify_attributes }}>
                {{ block.settings.custom_liquid }}
              </div>

            {%- when '@app' -%}
              <div class="product-app" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
          {%- endcase -%}
        {%- endfor -%}

        {% liquid
          assign full_details_button_tag = 'a'
          if featured_product == blank
            assign full_details_button_tag = 'button'
          endif
        %}
        <{{ full_details_button_tag }}
          class="button button--tertiary featured-product__full-details focus-inset"
          {% if featured_product != blank %}
            href="{{ featured_product.url }}"
            target="_blank"
          {% else %}
            aria-disabled="true"
          {% endif %}
        >
          <span>
            {{- 'products.product.view_details' | t -}}
          </span>
        </{{ full_details_button_tag }}>
      </div>
    </div>
  </div>
</div>

{% comment %} product structured data for SEO {% endcomment %}
{%- unless template contains 'product' -%}
  {%- if featured_product != blank -%}
    <script type="application/ld+json">
      {{ featured_product | structured_data }}
    </script>
  {%- endif -%}
{%- endunless -%}

{%- if first_3d_model and featured_product != blank -%}
  <script type="application/json" id="ProductJSON-{{ featured_product.id }}">
    {{ featured_product.media | where: 'media_type', 'model' | json }}
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.featured-product.name",
  "tag": "section",
  "class": "featured-product-section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["*"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product_item",
      "label": "t:sections.featured-product.settings.product_item.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "enable_border_top",
      "default": true,
      "label": "t:sections.all.borders.enable_border_top.label"
    },
    {
      "type": "checkbox",
      "id": "enable_border_bottom",
      "default": false,
      "label": "t:sections.all.borders.enable_border_bottom.label"
    },
    {
      "type": "checkbox",
      "id": "enable_equal_columns",
      "default": false,
      "label": "Equal column widths on desktop"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_heading_group.header.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.featured-product.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_font",
      "options": [
        {
          "value": "heading",
          "label": "t:sections.all.heading_font.options__1.label"
        },
        {
          "value": "body",
          "label": "t:sections.all.heading_font.options__2.label"
        }
      ],
      "default": "body",
      "label": "t:sections.all.heading_font.label",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h6",
          "label": "t:sections.all.heading_size.options__6.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        }
      ],
      "default": "h6",
      "label": "t:sections.all.heading_size.label",
      "visible_if": "{{ section.settings.heading != blank and section.settings.heading_font == 'heading' }}"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "checkbox",
      "id": "heading_group_button_show",
      "label": "t:sections.all.button.button_show.label",
      "default": false
    },
    {
      "type": "text",
      "id": "heading_group_button_label",
      "label": "t:sections.all.button.button_label.label",
      "default": "t:sections.all.button.button_label.default_shop_all",
      "visible_if": "{{ section.settings.heading_group_button_show }}"
    },
    {
      "type": "url",
      "id": "heading_group_button_link",
      "label": "t:sections.all.button.button_link.label",
      "visible_if": "{{ section.settings.heading_group_button_show }}"
    },
    {
      "type": "select",
      "id": "heading_group_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "tertiary",
      "label": "t:sections.all.button.button_style.label",
      "visible_if": "{{ section.settings.heading_group_button_show }}"
    },
    {
      "type": "checkbox",
      "id": "heading_group_enable_border_bottom",
      "default": true,
      "label": "t:sections.all.borders.enable_border_bottom.label",
      "visible_if": "{{ section.settings.heading != blank or section.settings.heading_group_button_show }}"
    },
    {
      "type": "header",
      "content": "t:sections.main-product.settings.header__media.content",
      "info": "t:sections.main-product.settings.header__media.info"
    },
    {
      "type": "select",
      "id": "desktop_gallery_order",
      "options": [
        {
          "value": "before",
          "label": "t:sections.main-product.settings.desktop_gallery_order.options__1.label"
        },
        {
          "value": "after",
          "label": "t:sections.main-product.settings.desktop_gallery_order.options__2.label"
        }
      ],
      "default": "before",
      "label": "t:sections.main-product.settings.desktop_gallery_order.label"
    },
    {
      "type": "select",
      "id": "mobile_gallery_order",
      "options": [
        {
          "value": "before",
          "label": "t:sections.main-product.settings.mobile_gallery_order.options__1.label"
        },
        {
          "value": "after",
          "label": "t:sections.main-product.settings.mobile_gallery_order.options__2.label"
        }
      ],
      "default": "before",
      "label": "t:sections.main-product.settings.mobile_gallery_order.label"
    },
    {
      "type": "select",
      "id": "desktop_media_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.main-product.settings.desktop_media_ratio.label"
    },
    {
      "type": "select",
      "id": "mobile_media_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.main-product.settings.mobile_media_ratio.label"
    },
    {
      "type": "select",
      "id": "image_fit",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.card.image_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.card.image_fit.options__2.label"
        }
      ],
      "default": "cover",
      "label": "t:sections.all.card.image_fit.label"
    },
    {
      "type": "checkbox",
      "id": "enable_border_between_images",
      "default": true,
      "label": "t:sections.featured-product.settings.enable_border_between_images.label"
    },
    {
      "type": "checkbox",
      "id": "show_no_media_placeholder",
      "default": true,
      "label": "t:sections.main-product.settings.show_no_media_placeholder.label"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "default": true,
      "label": "t:sections.main-product.settings.enable_video_looping.label"
    },
    {
      "type": "checkbox",
      "id": "enable_video_autoplay",
      "default": false,
      "label": "t:sections.main-product.settings.enable_video_autoplay.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
