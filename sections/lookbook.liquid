{{ 'section-lookbook.css' | asset_url | stylesheet_tag }}
<script src="{{ 'lookbook.js' | asset_url }}" defer="defer"></script>

{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{% endstyle %}

{% liquid
  if section.settings.aspect_ratio == 'landscape'
    assign card_padding_bottom = '75'
  elsif section.settings.aspect_ratio == 'portrait'
    assign card_padding_bottom = '113.4'
  elsif section.settings.aspect_ratio == 'square'
    assign card_padding_bottom = '100'
  elsif section.settings.aspect_ratio == 'adapt'
    assign card_padding_bottom = 0
  endif
%}
{%- style -%}
  {% if section.settings.info_type == 'static' %}

    .lookbook-{{ section.id }} .lookbook__image-wrapper {
      display: flex;
      position: relative;
    }

    .lookbook-{{ section.id }} .lookbook__image-wrapper::before {
      content: '';
      display: block;
      width: 0;
      padding-bottom: {{ card_padding_bottom }}%;
    }
    {% else %}

    .lookbook-{{ section.id }} .lookbook__image-wrapper {
      display: flex;
      position: relative;
    }

    .lookbook-{{ section.id }} .lookbook__image-wrapper::before {
      content: '';
      display: block;
      width: 0;
      padding-bottom: {{ card_padding_bottom }}%;
    }

    @media (min-width: 750px) {
      .lookbook-{{ section.id }} .lookbook__image-wrapper {
        position: absolute;
        inset: 0;
      }
      .lookbook-{{ section.id }} .lookbook__image-wrapper::before {
        display: none;
      }
      .lookbook-{{ section.id }} .lookbook__item::before {
        content: '';
        display: block;
        width: 0;
        padding-bottom: {{ card_padding_bottom }}%;
      }
    }

    {% endif %}
{%- endstyle -%}

<div
  class="lookbook lookbook-{{ section.id }} color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding{% if section.settings.enable_border_top %} section-border-top{% endif %}{% if section.settings.enable_border_bottom %} section-border-bottom{% endif %}"
  data-info-type="{{ section.settings.info_type }}"
>
  {% comment %} RENDER HEADING GROUP {% endcomment %}
  {% render 'heading-group', settings: section.settings, class: 'lookbook-header', has_slider_controls: true %}

  {% comment %} RENDER MAIN CONTENT {% endcomment %}
  {%- if section.blocks.size > 0 -%}
    <div
      class="lookbook__content column--{{section.settings.items_per_row}} swiper swiper--lookbook"
      data-items-per-row="{{ section.settings.items_per_row }}"
    >
      <div class="lookbook__blocks lookbook__blocks--{{section.settings.items_per_row}} lookbook__blocks--{{ section.settings.layout }}  swiper-wrapper">
        {%- for block in section.blocks -%}
          <div
            class="lookbook__item{% if section.settings.info_type == 'static' %} static-info{% endif %} lookbook__item--{{ section.settings.aspect_ratio }} horizontal-align__{{ section.settings.content_horizontal_alignment }} color-{{ section.settings.card_color_scheme }} swiper-slide"
            {{ block.shopify_attributes }}
          >
            <div class="lookbook__image-wrapper">
              {% comment %} Card image settings {% endcomment %}
              {%- liquid
                assign image_styles = 'object-fit: ' | append: section.settings.object_fit
                if section.settings.aspect_ratio == 'landscape'
                  assign settings_aspect_ratio = 1.26
                elsif section.settings.aspect_ratio == 'portrait'
                  assign settings_aspect_ratio = 0.88
                else
                  assign settings_aspect_ratio = 1
                endif
              -%}

              {%- if block.settings.card_image != blank -%}
                {% liquid
                  assign card_image = block.settings.card_image

                  assign calc_ratio = 1
                  if block.settings.card_image.aspect_ratio > settings_aspect_ratio
                    assign calc_ratio = card_image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
                  endif

                  assign image_loading = 'lazy'

                  if section.index == 1 and forloop.index == 1
                    assign image_loading = 'eager'
                  endif
                %}

                {%- capture image_sizes -%}
                  {%- if section.settings.items_per_row == 1 -%}
                    calc(100vw * {{ calc_ratio }})
                  {%- elsif section.settings.items_per_row == 2 -%}
                    (min-width: 576px) calc({{ calc_ratio }} * 50vw), calc(100vw * {{ calc_ratio }})
                  {%- elsif section.settings.items_per_row == 3 -%}
                    (min-width: 990px) calc({{ calc_ratio }} * 33.3vw), (min-width: 576px) calc({{ calc_ratio }} * 50vw), calc(100vw * {{ calc_ratio }})
                  {%- elsif section.settings.items_per_row == 4 -%}
                    (min-width: 1200px) calc({{ calc_ratio }} * 25vw), (min-width: 576px) calc({{ calc_ratio }} * 50vw), calc(100vw * {{ calc_ratio }})
                  {%- endif -%}
                {%- endcapture -%}

                {{
                  card_image
                  | image_url: width: card_image.width
                  | image_tag:
                    width: card_image.width,
                    height: card_image.height,
                    widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
                    sizes: image_sizes,
                    class: 'lookbook__image',
                    style: image_styles,
                    loading: image_loading
                }}
              {%- else -%}
                {% liquid
                  assign index = forloop.index | modulo: 3 | plus: 1
                %}
                {{ 'hero-apparel-' | append: index | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}

              {%- if block.settings.overlay_opacity != 0 -%}
                <span
                  class="lookbook__overlay"
                  style="opacity: {{ block.settings.overlay_opacity | times: 0.01 }};"
                ></span>
              {%- endif -%}
            </div>
            {% liquid
              assign has_content_button = false

              if block.settings.list_button_show and block.settings.list_button_label != blank
                assign has_content_button = true
              endif

              assign has_info_bottom = false
              if block.settings.card_description != blank or has_content_button
                assign has_info_bottom = true
              endif

              assign has_info_top = false
              if block.settings.card_heading != blank
                assign has_info_top = true
              endif

              if section.settings.info_type == 'dropdown' and has_info_bottom
                assign has_info_top = true
              endif
            %}

            {%- if has_info_top or has_info_bottom -%}
              <div class="lookbook__info {% if section.settings.enable_border_info %} info--border {% endif %}">
                {%- if has_info_top -%}
                  <div class="lookbook__info-top {% if section.settings.info_type == 'dropdown' and has_info_bottom %} lookbook__info-top--with-arrow{% endif %}">
                    {%- if block.settings.card_heading != blank -%}
                      <{{ block.settings.card_heading_tag | default: 'h3' }} class="lookbook__info-heading {% if block.settings.card_heading_font == 'heading'%}{{ block.settings.card_heading_size }}{% elsif block.settings.card_heading_font == 'subtitle' %}subtitle{% else %}title font--body{% endif %}">
                        {{- block.settings.card_heading -}}
                      </{{ block.settings.card_heading_tag | default: 'h3' }}>
                    {%- endif -%}

                    {%- if section.settings.info_type == 'dropdown' and has_info_bottom -%}
                      <div class="lookbook__info-top-icon">
                        {%- render 'icon-caret-right' -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- if has_info_bottom -%}
                  <div class="lookbook__info-bottom">
                    <div class="lookbook__info-bottom-inner">
                      {%- if block.settings.card_description != blank -%}
                        <p class="lookbook__info-description richtext-link-inside body-small">
                          {{ block.settings.card_description }}
                        </p>
                      {%- endif -%}

                      {%- if has_content_button -%}
                        {% render 'button',
                          btn_label: block.settings.list_button_label,
                          btn_style: block.settings.list_button_style,
                          btn_link: block.settings.list_button_link,
                          class: 'lookbook__info-btn'
                        %}
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if block.settings.card_overlay_link != blank -%}
              <a
                href="{{ block.settings.card_overlay_link }}"
                class="lookbook__link-overlay focus-inset"
                aria-label="{{ block.settings.card_heading }}"
                {% if settings.links_blank and block.settings.card_overlay_link.type == 'external_link' %}
                  target="_blank"
                {% endif %}
              ></a>
            {%- endif -%}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

