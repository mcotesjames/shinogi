{{ 'section-social-media.css' | asset_url | stylesheet_tag }}
<script src="{{ 'social-media.js' | asset_url }}" defer="defer"></script>

{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{% endstyle %}

<div
  class="social-media section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} background {% if section.settings.enable_border_top == true %} section-border-top{% endif %}{% if section.settings.enable_border_bottom %} section-border-bottom{% endif %}"
>
  {% render 'heading-group', settings: section.settings, class: 'social-media-header' %}

  <div class="content social-media-content">
    {% liquid
      if section.settings.list_button_show and section.settings.list_button_label != blank
        assign display_button = true
      else
        assign display_button = false
      endif
    %}
    {%- if section.settings.social_media_name != blank or display_button -%}
      <div class="social-media-content__info container">
        {%- if section.settings.social_media_name != blank -%}
          <p class="social-media-content__info-name">{{ section.settings.social_media_name }}</p>
        {%- endif -%}
        {%- if display_button %}
          {% render 'button',
            btn_label: section.settings.list_button_label,
            btn_style: section.settings.list_button_style,
            btn_link: section.settings.list_button_link,
            class: 'social-media-content__button'
          %}
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="social-media-content__slider{% if section.settings.enable_fullscreen == false %} container{% endif %}">
        {% assign slider_speed = 51 | minus: section.settings.slider_speed | times: 1000 %}
        <div
          class="social-media-slider swiper"
          data-stop-on-hover="{{ section.settings.slider_stop_on_hover }}"
          data-speed="{{ slider_speed }}"
          data-social-slider-id="{{ section.id }}"
          data-slides-per-view-desktop="{{ section.settings.slides_per_view_desktop }}"
          data-slides-per-view-mobile="{{ section.settings.slides_per_view_mobile }}"
          style="--sm-slider-slides-per-view-desktop: {{ section.settings.slides_per_view_desktop }}; --sm-slider-slides-per-view-mobile: {{ section.settings.slides_per_view_mobile }}"
        >
          <div
            class="social-media-slider-wrapper swiper-wrapper social-slider-{{ section.id }}"
            style="--sm-slider-slides-per-view-desktop: {{ section.settings.slides_per_view_desktop }}; --sm-slider-slides-per-view-mobile: {{ section.settings.slides_per_view_mobile }}"
          >
            {% liquid
              assign slider_arr = section.blocks
            %}
            {%- for block in slider_arr -%}
              <div
                class="social-media-slide swiper-slide social-media-slide--{{ section.settings.aspect_ratio }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.image != blank -%}
                  {%- liquid
                    assign object_fit = 'object-fit: ' | append: section.settings.object_fit

                    assign image_loading = 'lazy'

                    if section.index == 1 and forloop.index <= 4
                      assign image_loading = 'eager'
                    endif

                    if section.settings.aspect_ratio == 'landscape'
                      assign settings_aspect_ratio = 1.35
                    elsif section.settings.aspect_ratio == 'portrait'
                      assign settings_aspect_ratio = 0.75
                    else
                      assign settings_aspect_ratio = 1
                    endif

                    assign calc_ratio = 1
                    if block.settings.image.aspect_ratio > settings_aspect_ratio
                      assign calc_ratio = block.settings.image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
                    endif
                  -%}
                  {%- capture desktop_image_sizes -%}
                      (min-width: 576px) calc(100vw / {{ section.settings.slides_per_view_desktop }}  * {{ calc_ratio }}),
                    {%- endcapture -%}

                  {%- capture mobile_image_sizes -%}
                      calc(100vw / {{ section.settings.slides_per_view_mobile }} * {{ calc_ratio }}),
                    {%- endcapture -%}
                  {% liquid
                    assign image_sizes = desktop_image_sizes | append: mobile_image_sizes
                  %}
                  {{
                    block.settings.image
                    | image_url: width: 3840
                    | image_tag:
                      width: block.settings.image.width,
                      height: block.settings.image.height,
                      sizes: image_sizes,
                      widths: '150, 171, 204, 375, 420, 550, 750, 1000, 1280, 1500, 1780, 2560, 3000, 3840',
                      style: object_fit,
                      loading: image_loading
                  }}
                {%- else -%}
                  {% assign image_index = forloop.index | modulo: 4 | plus: 1 %}
                  {{ 'collection-apparel-' | append: image_index | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

