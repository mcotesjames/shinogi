{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

<div class="customer account order">
  <div class="container customer-container">
    {%- assign btn_label = 'customer.order.link_back' | t -%}
    {%- if btn_label and routes.account_url -%}
      {% render 'button',
        btn_label: btn_label,
        btn_style: 'primary',
        btn_link: routes.account_url,
        class: 'orders-link-back'
      %}
    {%- endif -%}
    <div class="account__wrapper">
      <div class="account__left">
        <div class="account__order-info">
          <h2 class="account__subtitle title font--body body-normal">
            {{ 'customer.order.title' | t: name: order.name }}
            <span class="order-status {% if order.financial_status == 'paid' %}order-status--success{%  elsif order.financial_status == 'unpaid' %} order-status--error{% endif %}">
              {{ order.financial_status_label -}}
            </span>
          </h2>
          <span class="font--body body-small">
            {{- 'customer.order.placed_on' | t }}

            {{ order.created_at | time_tag: format: 'date_at_time' -}}
          </span>

          {%- if order.cancelled -%}
            {%- assign cancelled_at = order.cancelled_at | time_tag: format: 'date_at_time' -%}
            <span class="body-small">
              {{- 'customer.order.cancelled_html' | t: date: cancelled_at }}
              {{ 'customer.order.cancelled_reason' | t: reason: order.cancel_reason_label -}}
            </span>
          {%- endif -%}
        </div>
        <div role="table" class="order-table order-table--details">
          <div class="visually-hidden">{{ 'customer.order.title' | t: name: order.name }}</div>
          <div class="row thead">
            <div id="ColumnProduct" class="body-small">{{- 'customer.order.product' | t -}}</div>
            <div id="ColumnPrice" class="body-small">{{- 'customer.order.price' | t -}}</div>
            <div id="ColumnQuantity" class="body-small">{{- 'customer.order.quantity' | t -}}</div>
            <div id="ColumnTotal" class="body-small">{{- 'customer.order.total' | t -}}</div>
          </div>

          {%- for line_item in order.line_items -%}
            <div class="row tbody">
              <div id="Row{{ line_item.key }}" data-label="{{ 'customer.order.product' | t }}">
                <div class="order-product">
                  <div class="order-product__details">
                    {% comment %} Vendor {% endcomment %}

                    {%- if settings.show_vendor and line_item.product.vendor != blank -%}
                      <p class="card__vendor subtitle subtitle--small">
                        {{ line_item.product.vendor }}
                      </p>
                    {%- endif -%}

                    {% comment %} Title {% endcomment %}
                    {%- if line_item.product.url != blank -%}
                      <a
                        href="{{ line_item.product.url }}"
                        class="order-product__name body-small"
                        aria-label="{{ line_item.product.title }}"
                      >
                        {{- line_item.product.title -}}
                      </a>
                    {%- else -%}
                      <p class="order-product__name body-small">
                        {{- line_item.product.title -}}
                      </p>
                    {%- endif -%}

                    {% comment %} Discount {% endcomment %}
                    {%- if line_item.line_level_discount_allocations.size != 0 -%}
                      <ul
                        role="list"
                        aria-label="{{ 'customer.order.discount' | t }}"
                        class="list-unstyled discounts"
                      >
                        {%- for discount_allocation in line_item.line_level_discount_allocations -%}
                          <li class="discounts__discount">
                            {% render 'icon-discount' %}
                            {{- discount_allocation.discount_application.title }} (-
                            {{- discount_allocation.amount | money -}}
                            )
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {% comment %} SKU {% endcomment %}
                    {%- if line_item.sku != blank -%}
                      <div class="order-product__sku body-small">
                        <span>{{- 'customer.order.sku' | t }}: </span>
                        <span>{{- line_item.sku -}}</span>
                      </div>
                    {%- endif -%}

                    {% comment %} Options {% endcomment %}
                    {%- assign property_size = line_item.properties | size -%}
                    {%- if line_item.product.has_only_default_variant == false
                      or property_size != 0
                      or line_item.selling_plan_allocation != null
                    -%}
                      <div class="properties">
                        {%- unless line_item.product.has_only_default_variant -%}
                          {%- assign options_arr = line_item.options_with_values | map: 'name' -%}
                          {%- assign values_arr = line_item.options_with_values | map: 'value' -%}
                          <dl class="properties__item body-small">
                            <dt class="visually-hidden">{{ options_arr | join: ' / ' }}</dt>
                            <dd class="properties__value">
                              {{ values_arr | join: ' / ' }}
                            </dd>
                          </dl>
                        {%- endunless -%}

                        {%- for property in line_item.properties -%}
                          {%- assign property_first_char = property.first | slice: 0 -%}
                          {%- if property.last != blank and property_first_char != '_' -%}
                            <dl class="properties__item body-small">
                              <dt>{{ property.first }}:</dt>
                              <dd>
                                {%- if property.last contains '/uploads/' -%}
                                  <a
                                    href="{{ property.last }}"
                                    class="hover-underlined-link"
                                    target="_blank"
                                  >
                                    {{- property.last | split: '/' | last -}}
                                  </a>
                                {%- else -%}
                                  {{- property.last -}}
                                {%- endif -%}
                              </dd>
                            </dl>
                          {%- endif -%}
                        {%- endfor -%}

                        {%- unless line_item.selling_plan_allocation == null -%}
                          <span>
                            {{ line_item.selling_plan_allocation.selling_plan.name }}
                          </span>
                        {%- endunless -%}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
              <div data-label="{{ 'customer.order.price' | t }}">
                {%- if line_item.original_price != line_item.final_price or line_item.unit_price_measurement -%}
                  <div>
                    {%- if line_item.original_price != line_item.final_price -%}
                      <div>
                        <span class="visually-hidden">{{ 'products.product.price.regular_price' | t }}</span>
                      </div>
                      <div>
                        <s class="body-small">
                          {% if settings.currency_code_enabled %}
                            {{ line_item.original_price | money_with_currency }}
                          {% else %}
                            {{ line_item.original_price | money }}
                          {% endif %}
                        </s>
                      </div>
                      <div>
                        <span class="visually-hidden">{{ 'products.product.price.sale_price' | t }}</span>
                      </div>
                      <div>
                        <span class="body-small">
                          {% if settings.currency_code_enabled %}
                            {{ line_item.final_price | money_with_currency }}
                          {% else %}
                            {{ line_item.final_price | money }}
                          {% endif %}
                        </span>
                      </div>
                    {%- else -%}
                      <div>
                        <span class="visually-hidden">{{ 'products.product.price.regular_price' | t }}</span>
                      </div>
                      <div class="body-small">
                        {% if settings.currency_code_enabled %}
                          {{ line_item.original_price | money_with_currency }}
                        {% else %}
                          {{ line_item.original_price | money }}
                        {% endif %}
                      </div>
                    {%- endif -%}
                    {%- if line_item.unit_price_measurement -%}
                      <div class="unit-price">
                        <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                        <span class="body-small">
                          {{- line_item.unit_price | unit_price_with_measurement: line_item.unit_price_measurement -}}
                        </span>
                      </div>
                    {%- endif -%}
                  </div>
                {%- else -%}
                  <span class="body-small">
                    {%- if settings.currency_code_enabled -%}
                      {{- line_item.final_price | money_with_currency -}}
                    {%- else -%}
                      {{- line_item.final_price | money -}}
                    {%- endif -%}
                  </span>
                {%- endif -%}
              </div>
              <div data-label="{{ 'customer.order.quantity' | t }}">
                <span class="body-small">{{ line_item.quantity }}</span>
              </div>
              <div data-label="{{ 'customer.order.total' | t }}">
                {%- if line_item.original_line_price != line_item.final_line_price -%}
                  <div>
                    <div>
                      <span class="visually-hidden">{{ 'products.product.price.regular_price' | t }}</span>
                    </div>
                    <div>
                      <s class="body-small">
                        {%- if settings.currency_code_enabled -%}
                          {{- line_item.original_line_price | money_with_currency }}
                        {%- else -%}
                          {{- line_item.original_line_price | money }}
                        {%- endif -%}
                      </s>
                    </div>
                    <div>
                      <span class="visually-hidden">{{ 'products.product.price.sale_price' | t }}</span>
                    </div>
                    <div>
                      <span class="body-small">
                        {% if settings.currency_code_enabled %}
                          {{- line_item.final_line_price | money_with_currency }}
                        {% else %}
                          {{- line_item.final_line_price | money }}
                        {% endif %}
                      </span>
                    </div>
                  </div>
                {%- else -%}
                  <span class="body-small">
                    {%- if settings.currency_code_enabled -%}
                      {{ line_item.original_line_price | money_with_currency }}
                    {%- else -%}
                      {{ line_item.original_line_price | money }}
                    {%- endif -%}
                  </span>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div role="table" class="order-table order-table--total">
          {% comment %} Subtotal {% endcomment %}
          <div class="row tbody">
            <span class="body-small">{{ 'customer.order.subtotal' | t }}</span>
            <span class="body-small">
              {% if settings.currency_code_enabled %}
                {{ order.line_items_subtotal_price | money_with_currency }}
              {% else %}
                {{ order.line_items_subtotal_price | money }}
              {% endif %}
            </span>
          </div>

          {% comment %} Shipping {% endcomment %}
          {%- if order.shipping_price > 0 -%}
            {%- for shipping_method in order.shipping_methods -%}
              <div class="row tbody">
                <span id="RowShipping" class="body-small">
                  {{- 'customer.order.shipping' | t }} ({{ shipping_method.title }})
                </span>
                <span data-label="{{ 'customer.order.shipping' | t }} ({{ shipping_method.title }})" class="body-small">
                  {% if settings.currency_code_enabled %}
                    {{ shipping_method.price | money_with_currency }}
                  {% else %}
                    {{ shipping_method.price | money }}
                  {% endif %}
                </span>
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="row tbody">
              <span id="RowShipping" class="body-small">{{ 'customer.order.shipping' | t }}</span>
              <span data-label="{{ 'customer.order.shipping' | t }}" class="body-small">
                {{ 'customer.orders.shipping_free' | t }}
              </span>
            </div>
          {% endif %}

          {% comment %} Discounts {% endcomment %}
          {%- if order.cart_level_discount_applications.size > 0 -%}
            {%- for discount_application in order.cart_level_discount_applications -%}
              <div class="row tbody row--discount">
                <span class="discounts__discount-label body-small">
                  {%- render 'icon-discount' -%}
                  {{ discount_application.title }}
                </span>
                <span class="discounts__discount-value body-small">
                  -
                  {%- if settings.currency_code_enabled -%}
                    {{ discount_application.total_allocated_amount | money_with_currency }}
                  {%- else -%}
                    {{ discount_application.total_allocated_amount | money }}
                  {%- endif -%}
                </span>
              </div>
            {%- endfor -%}
          {%- endif -%}

          {% comment %} Taxes {% endcomment %}
          {%- for tax_line in order.tax_lines -%}
            <div class="row tbody">
              <span id="RowTax" class="body-small">
                {{- 'customer.order.tax' | t }} ({{ tax_line.title }}
                {{ tax_line.rate | times: 100 }}%)
              </span>
              <span
                data-label="{{ 'customer.order.tax' | t }} ({{ tax_line.title }} {{ tax_line.rate | times: 100 }}%)"
                class="body-small"
              >
                {% if settings.currency_code_enabled %}
                  {{ tax_line.price | money_with_currency }}
                {% else %}
                  {{ tax_line.price | money }}
                {% endif %}
              </span>
            </div>
          {%- endfor -%}

          {% comment %} Duties {% endcomment %}
          {%- if order.total_duties -%}
            <div class="row tbody">
              <span id="RowDuties" class="body-small">{{ 'customer.orders.total_duties' | t }}</span>
              <span data-label="{{ 'customer.orders.total_duties' | t }}" class="body-small">
                {% if settings.currency_code_enabled %}
                  {{ order.total_duties | money_with_currency }}
                {% else %}
                  {{ order.total_duties | money }}
                {% endif %}
              </span>
            </div>
          {%- endif -%}

          {% comment %} Refund {% endcomment %}
          {%- if order.total_refunded_amount > 0 -%}
            <div class="row tbody">
              <span id="RowTotalRefund" class="body-small">
                {{ 'customer.orders.total_refunded' | t }}
              </span>
              <span data-label="{{ 'customer.orders.total_refunded' | t }}" class="body-small">
                {% if settings.currency_code_enabled %}
                  {{ order.total_refunded_amount | money_with_currency }}
                {% else %}
                  {{ order.total_refunded_amount | money }}
                {% endif %}
              </span>
            </div>
          {%- endif -%}

          {% comment %} Total {% endcomment %}
          <div class="row tbody row--total">
            <span id="RowTotal" class="body-small">{{- 'customer.order.total' | t -}}</span>
            <span data-label="{{ 'customer.order.total' | t }}" class="body-small">
              {{- order.total_net_amount | money_with_currency -}}
              {% comment %}
                {% if settings.currency_code_enabled %}
                  {{- order.total_net_amount | money_with_currency -}}
                {% else %}
                  {{- order.total_net_amount | money -}}
                {% endif %}
              {% endcomment %}
            </span>
          </div>
        </div>
      </div>

      <div class="account__right">
        {%- if order.billing_address != null -%}
          <h4 class="account__subtitle title font--body body-normal">
            {{- 'customer.order.billing_address' | t -}}
          </h4>
        {%- endif -%}
        <div class="address-list__item account-address" data-address>
          <div class="address-list__item-inner">
            <div class="address-list__item-wrapper">
              <div class="address-list__item-heading">
                <h5 class=" address-list__item-title title font--body body-small">
                  {{- 'customer.order.payment_status' | t }}
                </h5>
                <span class="body-small order-status{% if order.financial_status == 'paid' %} order-status--success{%  elsif order.fulfillment_status == 'unpaid' %} order-status--error{% endif %}">
                  {{ order.financial_status_label -}}
                </span>
              </div>

              {%- if order.billing_address != null -%}
                <ul class="account-address__list list-unstyled">
                  <li class="account-address__item account-address__item-name">
                    {%- if order.billing_address.name != blank -%}
                      <span class="address-list-lines__value ">
                        {{- order.billing_address.name -}}
                      </span>
                    {%- endif -%}
                  </li>

                  <li>
                    {%- if order.billing_address.address1 != blank -%}
                      <span class="account-address__item body-small body-small">
                        {{- order.billing_address.address1 -}}
                      </span>
                    {%- endif -%}
                    {%- if order.billing_address.address2 != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.billing_address.address2 -}}
                      </span>
                    {%- endif -%}

                    {%- if order.billing_address.city != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.billing_address.city -}}
                      </span>
                    {%- endif -%}

                    {%- if order.billing_address.province != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.billing_address.province -}}
                      </span>
                    {%- endif -%}

                    {%- if order.billing_address.zip != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.billing_address.zip -}}
                      </span>
                    {%- endif -%}

                    {%- if order.billing_address.country != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.billing_address.country -}}
                      </span>
                    {%- endif -%}

                    {%- if order.billing_address.company != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.billing_address.company -}}
                      </span>
                    {%- endif -%}

                    {%- if order.billing_address.phone != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.billing_address.phone -}}
                      </span>
                    {%- endif -%}
                  </li>
                </ul>
              {%- endif -%}
            </div>
          </div>
        </div>
        {%- if order.shipping_address != null -%}
          <h4 class="account__subtitle title font--body body-normal account__subtitle--margin-top">
            {{- 'customer.order.shipping_address' | t -}}
          </h4>
        {%- endif -%}
        <div class="address-list__item account-address" data-address>
          <div class="address-list__item-inner">
            <div class="address-list__item-wrapper">
              <div class="address-list__item-heading">
                <h5 class="h5 address-list__item-title title font--body body-small">
                  {{- 'customer.order.fulfillment_status' | t }}
                </h5>
                <span class="body-small order-status{% if order.fulfillment_status == 'fulfilled' %} order-status--success{%  elsif order.fulfillment_status == 'unfulfilled' %} order-status--error{% endif %}">
                  {{- order.fulfillment_status_label -}}
                </span>
              </div>

              {%- if order.shipping_address != null -%}
                <ul class="account-address__list account-address__default list-unstyled account-address__list--margin-bottom">
                  {%- if order.shipping_address.name != blank -%}
                    <li class="account-address__item account-address__item-name">
                      <span class="address-list-lines__value">
                        {{- order.shipping_address.name -}}
                      </span>
                    </li>
                  {%- endif -%}

                  <li>
                    {%- if order.shipping_address.address1 != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.shipping_address.address1 -}}
                      </span>
                    {%- endif -%}
                    {%- if order.shipping_address.address2 != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.shipping_address.address2 -}}
                      </span>
                    {%- endif -%}

                    {%- if order.shipping_address.city != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.shipping_address.city -}}
                      </span>
                    {%- endif -%}

                    {%- if order.shipping_address.province != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.shipping_address.province -}}
                      </span>
                    {%- endif -%}

                    {%- if order.shipping_address.zip != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.shipping_address.zip -}}
                      </span>
                    {%- endif -%}

                    {%- if order.shipping_address.country != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.shipping_address.country -}}
                      </span>
                    {%- endif -%}

                    {%- if order.shipping_address.company != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.shipping_address.company -}}
                      </span>
                    {%- endif -%}

                    {%- if order.shipping_address.phone != blank -%}
                      <span class="account-address__item body-small">
                        {{- order.shipping_address.phone -}}
                      </span>
                    {%- endif -%}
                  </li>
                </ul>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="account__log-out">
      <a
        class="account__log-out-link button button--tertiary"
        href="{{ routes.account_logout_url }}"
      >
        <span class="account__log-out-label body-small">{{ 'customer.log_out' | t }}</span>
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-order.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ]
}
{% endschema %}
