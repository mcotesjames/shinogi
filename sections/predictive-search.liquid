{%- if predictive_search.performed == true -%}
  <div id="predictive-search-results" role="listbox" tabindex="-1">
    {%- if predictive_search.resources.products.size > 0
      or predictive_search.resources.collections.size > 0
      or predictive_search.resources.articles.size > 0
      or predictive_search.resources.pages.size > 0
    -%}
      <div
        id="predictive-search-results-groups-wrapper"
        class="predictive-search__results-groups-wrapper{% unless predictive_search.resources.products.size > 0 %} predictive-search__results-groups-wrapper--no-products{% endunless %}{% unless predictive_search.resources.queries.size > 0 or predictive_search.resources.collections.size > 0 %} predictive-search__results-groups-wrapper--no-suggestions{% endunless %}"
      >
        <div class="predictive-search__result-group">
          <div class="predictive-search__result-tabs">
            {%- if predictive_search.resources.queries.size > 0 -%}
              <button
                class="button button--primary predictive-search__result-tab focus-inset active"
                data-type-target="queries"
              >
                <div class="button__content">
                  <span
                    id="predictive-search-queries"
                    class="predictive-search__result-tab-title button__label"
                    data-label="{{- 'general.search.queries' | t -}}"
                  >
                    {{- 'general.search.queries' | t -}}
                  </span>
                </div>
              </button>
            {%- endif -%}
            {%- if predictive_search.resources.products.size > 0 -%}
              <button
                class="button predictive-search__result-tab focus-inset{% if predictive_search.resources.queries == blank %} active button--primary{% else %} button--secondary{% endif %}"
                data-type-target="products"
              >
                <div class="button__content">
                  <span
                    id="predictive-search-products"
                    class="predictive-search__result-tab-title button__label"
                    data-label="{{- 'general.search.products' | t -}}"
                  >
                    {{- 'general.search.products' | t -}}
                  </span>
                </div>
              </button>
            {% endif %}
            {%- if predictive_search.resources.collections.size > 0 -%}
              <button
                class="button predictive-search__result-tab focus-inset{% if predictive_search.resources.queries == blank and predictive_search.resources.products == blank %} active button--primary{% else %} button--secondary{% endif %}"
                data-type-target="collections"
              >
                <div class="button__content">
                  <span
                    id="predictive-search-collections"
                    class="predictive-search__result-tab-title button__label"
                    data-label="{{- 'general.search.collections' | t -}}"
                  >
                    {{- 'general.search.collections' | t -}}
                  </span>
                </div>
              </button>
            {% endif %}
            {%- if predictive_search.resources.articles.size > 0 -%}
              <button
                class="button predictive-search__result-tab focus-inset{% if predictive_search.resources.queries == blank and predictive_search.resources.products == blank and predictive_search.resources.collections == blank %} active button--primary{% else %} button--secondary{% endif %}"
                data-type-target="articles"
              >
                <div class="button__content">
                  <span
                    id="predictive-search-articles"
                    class="predictive-search__result-tab-title button__label"
                    data-label="{{- 'general.search.articles' | t -}}"
                  >
                    {{- 'general.search.articles' | t -}}
                  </span>
                </div>
              </button>
            {% endif %}
            {%- if predictive_search.resources.pages.size > 0 -%}
              <button
                class="button predictive-search__result-tab focus-inset{% if predictive_search.resources.queries == blank and predictive_search.resources.products == blank and predictive_search.resources.collections == blank and predictive_search.resources.articles == blank %} active button--primary{% else %} button--secondary{% endif %}"
                data-type-target="pages"
              >
                <div class="button__content">
                  <span
                    id="predictive-search-pages"
                    class="predictive-search__result-tab-title button__label"
                    data-label="{{- 'general.search.pages' | t -}}"
                  >
                    {{- 'general.search.pages' | t -}}
                  </span>
                </div>
              </button>
            {% endif %}
          </div>

          {% comment %} render results {% endcomment %}
          {%- if predictive_search.resources.queries.size > 0 -%}
            <div class="predictive-search-results-wrapper">
              <div
                id="predictive-search-results-queries-list"
                class="predictive-search__results-list predictive-search__results-list_queries list-unstyled"
                role="group"
                aria-labelledby="predictive-search-queries"
                tabindex="-1"
                data-type="queries"
              >
                <div class="header__search-popular-links first-column">
                  {%- for query in predictive_search.resources.queries limit: 4 -%}
                    <div class="header__search-popular-link-wrapper ">
                      <a
                        href="{{ query.url }}"
                        class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset{% if forloop.index < 5 %} first-column{% else %} second-column{% endif %}"
                        role="option"
                      >
                        <span>{{ query.styled_text }}</span>
                      </a>
                    </div>
                  {%- endfor -%}
                </div>

                {% if predictive_search.resources.queries.size > 4 %}
                  <div class="header__search-popular-links second-column">
                    {%- for query in predictive_search.resources.queries offset: 4 limit: 4 -%}
                      <div class="header__search-popular-link-wrapper ">
                        <a
                          href="{{ query.url }}"
                          class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset{% if forloop.index < 5 %} first-column{% else %} second-column{% endif %}"
                          role="option"
                        >
                          <span>{{ query.styled_text }}</span>
                        </a>
                      </div>
                    {%- endfor -%}
                  </div>
                {% endif %}
              </div>
            </div>
          {%- endif -%}
          {%- if predictive_search.resources.products.size > 0 -%}
            <div class="predictive-search-results-wrapper">
              <div
                id="predictive-search-results-products-list"
                class="predictive-search__results-list predictive-search__results-list_products list-unstyled"
                role="group"
                aria-labelledby="predictive-search-products"
                tabindex="-1"
                data-type="products"
              >
                <div class="header__search-popular-links first-column">
                  {%- for product in predictive_search.resources.products limit: 4 -%}
                    <div class="header__search-popular-link-wrapper">
                      <a
                        href="{{ product.url }}"
                        class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset"
                        role="option"
                      >
                        <span>{{- product.title -}}</span>
                      </a>
                    </div>
                  {%- endfor -%}
                </div>

                {% if predictive_search.resources.products.size > 4 %}
                  <div class="header__search-popular-links second-column">
                    {%- for product in predictive_search.resources.products offset: 4 limit: 4 -%}
                      <div class="header__search-popular-link-wrapper">
                        <div class="header__search-popular-link-wrapper">
                          <a
                            href="{{ product.url }}"
                            class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset"
                            role="option"
                          >
                            <span>{{- product.title -}}</span>
                          </a>
                        </div>
                      </div>
                    {%- endfor -%}
                  </div>
                {% endif %}
              </div>
            </div>
          {%- endif -%}
          {%- if predictive_search.resources.collections.size > 0 -%}
            <div class="predictive-search-results-wrapper">
              <div
                id="predictive-search-results-collections-list"
                class="predictive-search__results-list predictive-search__results-list_collections list-unstyled"
                role="group"
                aria-labelledby="predictive-search-collections"
                data-type="collections"
              >
                <div class="header__search-popular-links first-column">
                  {%- for collection in predictive_search.resources.collections limit: 4 -%}
                    <div class="header__search-popular-link-wrapper">
                      <a
                        href="{{ collection.url }}"
                        class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset{% if forloop.index < 5 %} first-column{% else %} second-column{% endif %}"
                        role="option"
                      >
                        <span>{{- collection.title -}}</span>
                      </a>
                    </div>
                  {%- endfor -%}
                </div>

                {% if predictive_search.resources.collections.size > 4 %}
                  <div class="header__search-popular-links second-column">
                    {%- for collection in predictive_search.resources.collections offset: 4 limit: 4 -%}
                      <div class="header__search-popular-link-wrapper">
                        <a
                          href="{{ collection.url }}"
                          class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset{% if forloop.index < 5 %} first-column{% else %} second-column{% endif %}"
                          role="option"
                        >
                          <span>{{- collection.title -}}</span>
                        </a>
                      </div>
                    {%- endfor -%}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
          {%- if predictive_search.resources.articles.size > 0 -%}
            <div class="predictive-search-results-wrapper">
              <div
                id="predictive-search-results-articles-list"
                class="predictive-search__results-list predictive-search__results-list_articles list-unstyled"
                role="group"
                aria-labelledby="predictive-search-articles"
                data-type="articles"
              >
                <div class="header__search-popular-links first-column">
                  {%- for article in predictive_search.resources.articles limit: 4 -%}
                    <div class="header__search-popular-link-wrapper">
                      <a
                        href="{{ article.url }}"
                        class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset{% if forloop.index < 5 %} first-column{% else %} second-column{% endif %}"
                        role="option"
                      >
                        <span>{{- article.title -}}</span>
                      </a>
                    </div>
                  {%- endfor -%}
                </div>

                {% if predictive_search.resources.articles.size > 4 %}
                  <div class="header__search-popular-links second-column">
                    {%- for article in predictive_search.resources.articles offset: 4 limit: 4 -%}
                      <div class="header__search-popular-link-wrapper">
                        <a
                          href="{{ article.url }}"
                          class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset{% if forloop.index < 5 %} first-column{% else %} second-column{% endif %}"
                          role="option"
                        >
                          <span>{{- article.title -}}</span>
                        </a>
                      </div>
                    {%- endfor -%}
                  </div>
                {% endif %}
              </div>
            </div>
          {%- endif -%}
          {%- if predictive_search.resources.pages.size > 0 -%}
            <div class="predictive-search-results-wrapper">
              <div
                id="predictive-search-results-pages-list"
                class="predictive-search__results-list predictive-search__results-list_pages list-unstyled"
                role="group"
                aria-labelledby="predictive-search-pages"
                data-type="pages"
              >
                <div class="header__search-popular-links first-column">
                  {%- for page in predictive_search.resources.pages limit: 4 -%}
                    <div class="header__search-popular-link-wrapper">
                      <a
                        href="{{ page.url }}"
                        class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset{% if forloop.index < 5 %} first-column{% else %} second-column{% endif %}"
                        role="option"
                      >
                        <span>{{ page.title }}</span>
                      </a>
                    </div>
                  {%- endfor -%}
                </div>

                {% if predictive_search.resources.pages.size > 4 %}
                  <div class="header__search-popular-links second-column">
                    {%- for page in predictive_search.resources.pages offset: 4 limit: 4 -%}
                      <div class="header__search-popular-link-wrapper">
                        <a
                          href="{{ page.url }}"
                          class="header__search-popular-link hover-underlined-link-secondary body-small focus-inset{% if forloop.index < 5 %} first-column{% else %} second-column{% endif %}"
                          role="option"
                        >
                          <span>{{ page.title }}</span>
                        </a>
                      </div>
                    {%- endfor -%}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}

          <span
            class="skip-to-close-button visually-hidden focus-inset"
            aria-label="{{- 'accessibility.skip_to_close' | t -}}"
            tabindex="0"
          >
            {{- 'accessibility.skip_to_close' | t -}}
          </span>
        </div>
      </div>
    {%- endif -%}

    <div class="predictive-search__loading-state" aria-hidden="true">
      {% render 'icon-loading' %}
    </div>
  </div>

  {%- if predictive_search.resources.products == blank
    and predictive_search.resources.collections == blank
    and predictive_search.resources.articles == blank
    and predictive_search.resources.pages == blank
  -%}
    <div class="predictive-search__empty">
      <p class="predictive-search__empty-title h6">
        {{- 'templates.search.no_results' | t: terms: predictive_search.terms -}}
      </p>
      <p class="predictive-search__empty-text body-small">
        {{- 'templates.search.no_results_text' | t -}}
      </p>
    </div>
  {% endif %}

  <span class="hidden" data-predictive-search-live-region-count-value>
    {% liquid
      assign total_results = predictive_search.resources.products.size
      echo 'templates.search.results_with_count_and_term' | t: count: total_results, terms: predictive_search.terms
    %}
  </span>
{%- endif -%}
