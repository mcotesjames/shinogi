{{ 'section-content-tabs.css' | asset_url | stylesheet_tag }}
<script src="{{ 'content-tabs.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}

  {%- if section.settings.full_height -%}
    @media screen and (min-width: 750px) {
      .section-{{ section.id }} .content-tabs__contents {
        min-height: 100vh;
        min-height: 100svh;
      }

      main > .content-tabs-section:first-child .section-{{ section.id }} .content-tabs__contents {
        min-height: calc(100vh - var(--announcement-height) - var(--header-height));
        min-height: calc(100svh - var(--announcement-height) - var(--header-height));
      }
    }
  {%- endif -%}
{%- endstyle -%}

<div class="content-tabs color-{{ section.settings.color_scheme }} background section-{{ section.id }}{% if section.settings.enable_border_top %} section-border-top{% endif %}{% if section.settings.enable_border_bottom %} section-border-bottom{% endif %}">
  {%- if section.settings.enable_heading_group -%}
    {% render 'heading-group', settings: section.settings, class: 'content-tabs-header' %}
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="content-tabs__wrapper">
      <div class="content-tabs__tabs">
        {%- if section.settings.enable_heading_group == false and section.settings.heading != blank -%}
          <{{ section.settings.heading_tag | default: "h2" }}
            class="title {% if section.settings.heading_font == 'heading'%}{{ section.settings.heading_size }} size--{{ section.settings.heading_size }}{% else %}font--body{% endif %} richtext-link-inside"
          >
            {{- section.settings.heading -}}
          </{{ section.settings.heading_tag | default: "h2" }}>
        {%- endif -%}

        <div class="content-tabs__tabs-list">
          {%- for block in section.blocks -%}
            <button
              class="button--unstyled content-tabs__tab subtitle focus-inset{% if forloop.first %} active{% endif %}"
              aria-label="{{ block.settings.block_heading }}"
              data-block-id="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <span>{{- block.settings.block_heading -}}</span>
            </button>
          {%- endfor -%}
        </div>
      </div>

      <div class="content-tabs__contents section-{{ section.id }}-padding">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'richtext_content' -%}
              <div
                class="content-tabs__content content-tabs__content--richtext{% if forloop.first %} active{% endif %}"
                data-block-id="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <div class="content-tabs__content-heading subtitle">
                  {{- block.settings.block_heading -}}
                </div>

                {% if block.settings.content_page.content != blank %}
                  <div class="rte">
                    {{- block.settings.content_page.content -}}
                  </div>
                {%- endif -%}

                {% if block.settings.richtext_content != blank %}
                  <div class="rte">
                    {{- block.settings.richtext_content -}}
                  </div>
                {%- endif -%}

                {%- if block.settings.show_button and block.settings.button_label != blank -%}
                  {% render 'button', settings: block.settings, class: 'content-tabs__content-btn' %}
                {%- endif -%}
              </div>

            {%- when 'collapsible_content' -%}
              <div
                class="content-tabs__content content-tabs__content--collapsible{% if forloop.first %} active{% endif %}"
                data-block-id="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <div class="content-tabs__content-heading subtitle">
                  {{- block.settings.block_heading -}}
                </div>

                <div class="content-tabs__collapsible">
                  {%- for i in (1..12) -%}
                    {%- liquid
                      assign enable_row_setting = 'enable_row_' | append: i
                      assign question_setting = 'question_' | append: i
                      assign answer_setting = 'answer_' | append: i
                      assign default_open_setting = 'default_open_' | append: i

                      assign enable_row = block.settings[enable_row_setting]
                      assign question = block.settings[question_setting]
                      assign answer = block.settings[answer_setting]
                      assign default_open = block.settings[default_open_setting]
                    -%}
                    {%- if enable_row and question != blank -%}
                      <div class="content-tabs__collapsible-block">
                        <button
                          class="content-tabs__collapsible-toggle button--unstyled focus-inset{% if default_open %} active{% endif %}"
                          aria-label="{{ question }}"
                        >
                          <span>{{- question -}}</span>
                          {% render 'icon-chevron' %}
                        </button>
                        <div class="content-tabs__collapsible-content rte{% if default_open %} active{% endif %}">
                          {{- answer -}}
                        </div>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                {%- if block.settings.show_button and block.settings.button_label != blank -%}
                  {% render 'button', settings: block.settings, class: 'content-tabs__content-btn' %}
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

