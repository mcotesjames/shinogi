{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{%- style -%}
  {% if section.settings.background_type == "full_height" %}
      .register.register--{{ section.id }} {
        min-height: calc(100vh - var(--announcement-height) - var(--header-height));
        min-height: calc(100svh - var(--announcement-height) - var(--header-height));
        padding-block: 2.4rem;
      }
  {% else %}
      .register.register--{{ section.id }} {
        padding-block: 3.2rem;
      }

      @media (min-width: 750px) {
        .register.register--{{ section.id }} {
          padding-block: 6.4rem;
        }
      }
  {% endif %}
{%- endstyle -%}

<div
  class="customer login register register--{{ section.id }} register--{{ section.settings.background_type }} container color-{{ section.settings.color_scheme_background }} container{% if section.settings.enable_background_image == true %} register--background-image{% endif %}"
  {% if section.settings.enable_background_image == true %}
    data-header-interaction="true"
    data-color-scheme="{{ section.settings.color_scheme_background }}"
  {% endif %}
>
  <div class="login__col color-{{ section.settings.color_scheme_content }}">
    <div class="register__form">
      <div class="form-header">
        <div class="form-header__inner">
          <h1 class=" login__title h6">
            {{ 'customer.register.title' | t }}
          </h1>
        </div>
      </div>
      {%- form 'create_customer', return_to: routes.account_url -%}
        <div class="register__fields-wrapper">
          <div class="field">
            <input
              type="text"
              name="customer[first_name]"
              id="RegisterForm-FirstName"
              dir="ltr"
              {% if form.first_name %}
                value="{{ form.first_name }}"
              {% endif %}
              autocomplete="given-name"
              placeholder="{{- 'customer.register.first_name' | t -}}"
              required
            >
            <label for="RegisterForm-FirstName" class="body-small">
              {{- 'customer.register.first_name' | t -}}
            </label>
          </div>
          <div class="field">
            <input
              type="text"
              name="customer[last_name]"
              id="RegisterForm-LastName"
              dir="ltr"
              {% if form.last_name %}
                value="{{ form.last_name }}"
              {% endif %}
              autocomplete="family-name"
              placeholder="{{- 'customer.register.last_name' | t -}}"
              required
            >
            <label for="RegisterForm-LastName" class="body-small">
              {{- 'customer.register.last_name' | t -}}
            </label>
          </div>
          <div class="field field--email">
            <input
              type="email"
              name="customer[email]"
              id="RegisterForm-email"
              dir="ltr"
              {% if form.email %}
                value="{{ form.email }}"
              {% endif %}
              spellcheck="false"
              autocapitalize="off"
              autocomplete="email"
              pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="RegisterForm-email-error"
              {% endif %}
              placeholder="{{ 'customer.login_page.email_placeholder' | t }}"
              required
            >
            <label for="RegisterForm-email" class="body-small">
              {{- 'customer.register.email' | t -}}
            </label>
            {%- if form.errors contains 'email' -%}
              <span
                id="RegisterForm-email-error"
                class="form__message form__message--error body-small"
              >
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}.
              </span>
            {%- endif -%}
          </div>
          <div class="field field--pass">
            <div class="field--pass-wrapper">
              <div class="button-pass-visibility">
                {% render 'icon-eye' %}
                {% render 'icon-eye-close' %}
              </div>
              <input
                type="password"
                name="customer[password]"
                id="RegisterForm-password"
                dir="ltr"
                aria-required="true"
                placeholder="{{ 'customer.login_page.password_placeholder' | t }}"
                {% if form.errors contains 'password' %}
                  aria-invalid="true"
                  aria-describedby="RegisterForm-password-error"
                {% endif %}
                required
              >
              <label for="RegisterForm-password" class="body-small">
                {{- 'customer.register.password' | t -}}
              </label>
            </div>

            {%- if form.errors contains 'password' -%}
              <span
                id="RegisterForm-password-error"
                class="form__message form__message--error body-small"
              >
                {{ form.errors.translated_fields.password | capitalize }}
                {{ form.errors.messages.password }}.
              </span>
            {%- endif -%}

            {%- if form.errors contains 'form' -%}
              <span
                id="RegisterForm-email-error"
                class="form__message form__message--error body-small"
              >
                {{- 'customer.login_page.customer_exist' | t -}}
              </span>
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.show_terms or section.settings.show_subscribe -%}
          <div class="field--terms">
            {% if section.settings.show_terms and shop.terms_of_service.url != blank %}
              <div class="field field--checkbox">
                <input
                  type="checkbox"
                  class="focus-inset"
                  name="terms"
                  id="terms"
                  aria-describedby="RegisterForm-terms-error"
                  required
                  oninvalid="this.classList.add('is-invalid')"
                  onchange="this.classList.remove('is-invalid')"
                >
                <label for="terms">
                  <span class="field__checkbox"></span>
                  <span class="field__label body-small">
                    {{- 'customer.register.terms' | t }}
                    <a href="{{ shop.terms_of_service.url }}" target="_blank">
                      {{- 'customer.register.terms_link' | t -}}
                    </a>
                  </span></label
                >

                <span id="RegisterForm-terms-error" class="form__message form__message--error">
                  {{- 'customer.register.terms_error' | t -}}
                </span>
              </div>
            {% endif %}
          </div>
          <div class="field--terms">
            {% if section.settings.show_subscribe %}
              <div class="field field--checkbox">
                <input
                  type="checkbox"
                  name="customer[accepts_marketing]"
                  value="true"
                  id="RegisterFormSubscribeConsent"
                >
                <label for="RegisterFormSubscribeConsent">
                  <span class="field__checkbox"></span>
                  <span class="field__label body-small">
                    {{ 'customer.register.newsletter' | t }}
                  </span>
                </label>
              </div>
            {% endif %}
          </div>
        {%- endif -%}

        <div class="login__buttons">
          <button
            type="submit"
            class="button button--primary register__create-acc focus-inset"
          >
            <div class="button__content">
              <span class="button__label" data-label="{{- 'customer.register.submit' | t -}}">
                {{- 'customer.register.submit' | t -}}
              </span>
            </div>
          </button>
        </div>
      {%- endform -%}
    </div>
    <div class="register__form-info color-{{ section.settings.color_scheme_content_2 }} background">
      <span>{{ 'customer.register.have_account' | t }}</span>
      {% assign login_btn_label = 'customer.login_page.title' | t %}
      {% render 'button',
        btn_label: login_btn_label,
        btn_style: 'transparent',
        btn_link: routes.account_login_url,
        class: 'register__to-sign-in'
      %}
    </div>
  </div>

  {% if section.settings.enable_background_image == true %}
    {% if section.settings.background_image != blank %}
      {% liquid
        assign image = section.settings.background_image

        assign image_styles = 'object-fit: cover;'
        assign calc_ratio_desktop = 1
        assign calc_ratio_mobile = 1

        assign desktop_aspect_ratio = 1.44
        assign mobile_aspect_ratio = 0.76
        if image.aspect_ratio > desktop_aspect_ratio
          assign calc_ratio_desktop = image.aspect_ratio | divided_by: desktop_aspect_ratio | round: 2
        endif

        if image.aspect_ratio > mobile_aspect_ratio
          assign calc_ratio_mobile = image.aspect_ratio | divided_by: desktop_aspect_ratio | round: 2
        endif

        assign image_loading = 'eager'
      %}

      {%- capture image_sizes -%}
        (min-width: 750px) calc(100vw * {{ calc_ratio_desktop }}), calc(100vw * {{ calc_ratio_mobile }})
      {%- endcapture -%}
      {{
        image
        | image_url: width: image.width
        | image_tag:
          width: image.width,
          height: image.height,
          widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
          sizes: image_sizes,
          class: 'login__image',
          style: image_styles,
          loading: image_loading
      }}
    {% else %}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'login__image placeholder-svg' }}
    {% endif %}

    {% if section.settings.overlay_opacity != 0 %}
      <span
        class="login__overlay"
        style="opacity: {{ section.settings.overlay_opacity | times: 0.01 }};"
      ></span>
    {% endif %}
  {%- endif %}
</div>

<script>
  window.onload = () => {
    typeof PasswordViewer !== 'undefined' && new PasswordViewer();
  };
</script>

{% schema %}
{
  "name": "t:sections.main-register.name",
  "tag": "section",
  "class": "register-section has-header-interaction",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme_content",
      "default": "background-1",
      "label": "t:sections.main-login.settings.color_scheme_content.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_content_2",
      "default": "background-2",
      "label": "t:sections.main-login.settings.color_scheme_content_2.label"
    },
    {
      "type": "checkbox",
      "id": "show_terms",
      "default": true,
      "label": "t:sections.main-register.settings.show_terms.label"
    },
    {
      "type": "checkbox",
      "id": "show_subscribe",
      "default": false,
      "label": "t:sections.main-register.settings.show_subscribe.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-login.settings.header_image.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_background",
      "default": "background-3",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "select",
      "id": "background_type",
      "options": [
        {
          "value": "adapt-to-content",
          "label": "t:sections.all.aspect_ratio.adapt_to_content.label"
        },
        {
          "value": "full_height",
          "label": "t:sections.all.aspect_ratio.full_height.label"
        }
      ],
      "default": "full_height",
      "label": "t:sections.main-login.settings.background_type.label"
    },

    {
      "type": "checkbox",
      "id": "enable_background_image",
      "label": "t:sections.all.background_image.label",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.all.background_image.label",
      "visible_if": "{{ section.settings.enable_background_image }}"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "unit": "%",
      "label": "t:sections.all.overlay_opacity.label",
      "visible_if": "{{ section.settings.enable_background_image }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ]
}
{% endschema %}
