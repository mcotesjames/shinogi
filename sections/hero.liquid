      "visible_if": "{{ section.settings.subheading != blank or section.settings.heading != blank or section.settings.description != blank }}"
    },
    {
      "type": "text_alignment",
      "id": "horizontal_alignment",
      "label": "t:sections.all.horizontal_alignment.label",
      "default": "center",
      "visible_if": "{{ section.settings.subheading != blank or section.settings.heading != blank or section.settings.description != blank }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
