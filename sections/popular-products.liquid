{{ 'section-popular-products.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'popular-products.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

<div
  class="popular-products color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding{% if section.settings.enable_border_top %} section-border-top{% endif %}{% if section.settings.enable_border_bottom %} section-border-bottom{% endif %}"
  data-layout="{{ section.settings.layout }}"
>
  {% comment %} RENDER HEADING GROUP {% endcomment %}
  {% liquid
    assign has_slider_controls = false
    if section.settings.layout == 'slider'
      assign has_slider_controls = true
    endif

    assign hide_tabs = false
    if section.blocks.size == 1 and section.blocks[0].settings.show_tab_label_for_single_block == false
      assign hide_tabs = true
    endif
  %}
  {% render 'heading-group',
    settings: section.settings,
    class: 'popular-products-header',
    products_tabs: section.blocks,
    has_slider_controls: has_slider_controls,
    hide_tabs: hide_tabs
  %}

  {% comment %} RENDER MAIN CONTENT {% endcomment %}
  {%- if section.blocks.size > 0 -%}
    <div
      class="popular-products__wrapper{% if section.settings.spacing == 'gap' %} container{% endif %}"
      style="--gap:{% if section.settings.spacing == 'gap' %}8px;{% else %}0px;{% endif %}"
    >
      {%- assign placeholder_numbers = '1|2|3|4' | split: '|' -%}
      {%- for block in section.blocks -%}
        {% comment %} for uniques color swatch input ID {% endcomment %}
        {% assign index_tab = forloop.index %}
        {% comment %} for random svg in placeholders {% endcomment %}
        {% assign block_index = forloop.index %}
        {% assign start_index = block_index | modulo: placeholder_numbers.size %}
        <div
          class="popular-products__layout popular-products__layout--spacing-{{ section.settings.spacing }}{% if forloop.index == 1 %} active{% endif %}{% if block.settings.product_list == blank %} popular-products__layout--placeholder{% endif %}{% if section.settings.layout == 'slider' %} js-popular-products-slider swiper{% endif %}"
          data-products-tab-id="{{ block.id }}"
          {{ block.shopify_attributes }}
          {% if section.settings.layout == 'slider' %}
            data-products-per-row="{{ section.settings.products_per_row }}"
            data-products-per-row-mobile="{{ section.settings.products_per_row_mobile }}"
            {% if section.settings.spacing == 'gap' %}
              data-space-between="8"
            {% else %}
              data-space-between="0"
            {% endif %}
          {% endif %}
        >
          <div class="popular-products__list popular-products__list--{{ section.settings.products_per_row }} popular-products__list--mobile-{{ section.settings.products_per_row_mobile }} popular-products__list--{{ section.settings.layout }}{% if section.settings.layout == 'slider' %} swiper-wrapper{% endif %}">
            {%- for product in block.settings.product_list -%}
              <div class="popular-products__item{% if section.settings.layout == 'slider' %} swiper-slide{% endif %}">
                {% assign section_id = section.id | append: block.id %}
                {% render 'product-card',
                  product_card_product: product,
                  section_obj: section,
                  section_id: section_id,
                  forloop_index: forloop.index,
                  columns: section.settings.products_per_row,
                  columns_mobile: section.settings.products_per_row_mobile,
                  index_tab: index_tab,
                  information_block_type: section.settings.information_block_type,
                  show_quick_add_overwrite: section.settings.show_quick_add,
                  quick_add_block_type: section.settings.quick_add_block_type,
                  show_quick_view_overwrite: section.settings.show_quick_view
                %}
              </div>
            {%- else -%}
              {% liquid
                assign count_placeholders = section.settings.products_per_row
                if section.settings.layout == 'slider'
                  assign count_placeholders = section.settings.products_per_row | times: 2
                endif
              %}
              {%- for i in (1..count_placeholders) -%}
                {% assign index = start_index | plus: i | modulo: placeholder_numbers.size %}
                {% assign placeholder_index = placeholder_numbers[index] %}
                <div class="popular-products__item{% if section.settings.layout == 'slider' %} swiper-slide{% endif %}">
                  {% render 'product-card-placeholder',
                    product_number: placeholder_index,
                    columns_mobile: section.settings.products_per_row_mobile,
                    information_block_type: section.settings.information_block_type,
                    show_quick_add_overwrite: section.settings.show_quick_add,
                    quick_add_block_type: section.settings.quick_add_block_type,
                    show_quick_view_overwrite: section.settings.show_quick_view
                  %}
                </div>
              {%- endfor -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.popular-products.name",
  "tag": "section",
  "class": "popular-products-section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "enable_border_top",
      "default": true,
      "label": "t:sections.all.borders.enable_border_top.label"
    },
    {
      "type": "checkbox",
      "id": "enable_border_bottom",
      "default": false,
      "label": "t:sections.all.borders.enable_border_bottom.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.all.section_layout.label",
      "options": [
        {
          "value": "slider",
          "label": "t:sections.all.section_layout.options__1.label"
        },
        {
          "value": "grid",
          "label": "t:sections.all.section_layout.options__2.label"
        }
      ],
      "default": "slider"
    },
    {
      "type": "select",
      "id": "spacing",
      "label": "t:sections.all.spacing.label",
      "options": [
        {
          "value": "border",
          "label": "t:sections.all.spacing.options__1.label"
        },
        {
          "value": "gap",
          "label": "t:sections.all.spacing.options__2.label"
        }
      ],
      "default": "border"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.all.products_per_row.label"
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "default": "1",
      "label": "t:sections.all.products_per_row_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.products_per_row_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.products_per_row_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.section_heading_group.header.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.heading.label",
      "default": "t:sections.popular-products.settings.heading.default"
    },
    {
      "type": "select",
      "id": "heading_font",
      "options": [
        {
          "value": "heading",
          "label": "t:sections.all.heading_font.options__1.label"
        },
        {
          "value": "body",
          "label": "t:sections.all.heading_font.options__2.label"
        }
      ],
      "default": "body",
      "label": "t:sections.all.heading_font.label",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h6",
          "label": "t:sections.all.heading_size.options__6.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        }
      ],
      "default": "h6",
      "label": "t:sections.all.heading_size.label",
      "visible_if": "{{ section.settings.heading != blank and section.settings.heading_font == 'heading' }}"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "checkbox",
      "id": "heading_group_button_show",
      "label": "t:sections.all.button.button_show.label",
      "default": false
    },
    {
      "type": "text",
      "id": "heading_group_button_label",
      "label": "t:sections.all.button.button_label.label",
      "default": "t:sections.all.button.button_label.default_shop_all",
      "visible_if": "{{ section.settings.heading_group_button_show == true }}"
    },
    {
      "type": "url",
      "id": "heading_group_button_link",
      "label": "t:sections.all.button.button_link.label",
      "visible_if": "{{ section.settings.heading_group_button_show == true }}"
    },
    {
      "type": "select",
      "id": "heading_group_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "tertiary",
      "label": "t:sections.all.button.button_style.label",
      "visible_if": "{{ section.settings.heading_group_button_show }}"
    },
    {
      "type": "checkbox",
      "id": "heading_group_enable_border_bottom",
      "default": true,
      "label": "t:sections.all.borders.enable_border_bottom.label",
      "visible_if": "{{ section.settings.heading != blank or section.settings.heading_group_button_show or section.settings.layout == 'slider' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.card.header_product_card.content"
    },
    {
      "type": "select",
      "id": "information_block_type",
      "label": "t:sections.all.card.information_block_type.label",
      "info": "t:sections.all.card.information_block_type.info",
      "options": [
        {
          "value": "static",
          "label": "t:sections.all.card.information_block_type.options__1.label"
        },
        {
          "value": "reveal",
          "label": "t:sections.all.card.information_block_type.options__2.label"
        }
      ],
      "default": "static",
      "visible_if": "{{ settings.product_card_type == 'overlay' }}"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "default": true,
      "label": "t:sections.all.card.show_quick_add.label",
      "info": "t:sections.all.card.show_quick_add.info"
    },
    {
      "type": "select",
      "id": "quick_add_block_type",
      "label": "t:sections.all.card.quick_add_block_type.label",
      "info": "t:sections.all.card.quick_add_block_type.info",
      "options": [
        {
          "value": "static",
          "label": "t:sections.all.card.quick_add_block_type.options__1.label"
        },
        {
          "value": "reveal",
          "label": "t:sections.all.card.quick_add_block_type.options__2.label"
        }
      ],
      "default": "reveal",
      "visible_if": "{{ settings.product_card_type == 'overlay' and section.settings.show_quick_add == true and section.settings.information_block_type == 'static' }}"
    },
    {
      "type": "checkbox",
      "id": "show_quick_view",
      "default": true,
      "label": "t:sections.all.card.show_quick_view.label",
      "info": "t:sections.all.card.show_quick_view.info",
      "visible_if": "{{ settings.quickview_show == true }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "t:sections.popular-products.blocks.tab.name",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "t:sections.popular-products.blocks.tab.settings.tab_label.label",
          "default": "t:sections.popular-products.blocks.tab.settings.tab_label.default"
        },
        {
          "type": "checkbox",
          "id": "show_tab_label_for_single_block",
          "label": "t:sections.popular-products.blocks.tab.settings.show_tab_label_for_single_block.label",
          "default": false
        },
        {
          "type": "product_list",
          "id": "product_list",
          "label": "t:sections.popular-products.blocks.tab.settings.product_list.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.popular-products.presets.name",
      "category": "t:sections.categories.products",
      "blocks": [
        {
          "type": "tab",
          "settings": {}
        }
      ]
    }
  ]
}
{% endschema %}
