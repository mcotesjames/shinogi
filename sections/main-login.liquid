{{ 'customer.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{% style %}
  {% if section.settings.background_type == "full_height" %}
      .login.login--{{ section.id }} {
        min-height: calc(100vh - var(--announcement-height) - var(--header-height));
        min-height: calc(100svh - var(--announcement-height) - var(--header-height));
        padding-block: 2.4rem;
      }
  {% else %}
      .login.login--{{ section.id }} {
        padding-block: 3.2rem;
      }

      @media (min-width: 750px) {
        .login.login--{{ section.id }} {
          padding-block: 6.4rem;
        }
      }
  {% endif %}
{% endstyle %}

<div
  class="customer login login--{{ section.id }} login--{{ section.settings.background_type }} color-{{ section.settings.color_scheme_background }} container{% if section.settings.enable_background_image == true %} login--background-image{% endif %}"
  {% if section.settings.enable_background_image == true %}
    data-header-interaction="true"
    data-color-scheme="{{ section.settings.color_scheme_background }}"
  {% endif %}
>
  <div class="login__col color-{{ section.settings.color_scheme_content }}">
    <div class="login__reset" id="recover">
      <div class="form-header">
        <div class="form-header__inner">
          <h2 class=" login__title h6">
            {{ 'customer.recover_password.title' | t }}
          </h2>
          <p class="body-small">{{ 'customer.recover_password.subtext' | t }}</p>
        </div>
      </div>
      <div>
        {%- form 'recover_customer_password' -%}
          {% assign recover_success = form.posted_successfully? %}
          <div class="field field--email">
            <input
              type="email"
              value=""
              name="email"
              id="RecoverEmail"
              dir="ltr"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
              autofocus
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="RecoverEmail-email-error"
                autofocus
              {% endif %}
              placeholder="{{ 'customer.login_page.email_placeholder' | t }}"
              required
            >
            <label for="RecoverEmail" class="body-small">
              {{- 'customer.login_page.email' | t -}}
            </label>
            {%- if form.errors -%}
              <small id="RecoverEmail-email-error" class="form__message">
                {{ form.errors.messages.form }}
              </small>
            {%- endif -%}
          </div>

          <div class="login__buttons">
            <button type="submit" class="button button--primary login__sign-in focus-inset">
              <div class="button__content">
                <span class="button__label" data-label="{{- 'customer.login_page.submit' | t -}}">
                  {{- 'customer.login_page.submit' | t -}}
                </span>
              </div>
            </button>

            <a
              class="button button--tertiary reset__sign-in anchor focus-inset"
              href="#login"
            >
              <span class="button__label">
                {{- 'customer.login_page.cancel' | t -}}
              </span>
            </a>
          </div>
        {%- endform -%}
      </div>
    </div>

    <div class="login__form" id="login">
      <div class="login__form-main color-{{ section.settings.color_scheme_content }} background">
        <div class="form-header">
          <div class="form-header__inner">
            <h1 class=" login__title h6">
              {{ 'customer.login_page.title' | t }}
            </h1>
          </div>
        </div>
        {%- if recover_success == true -%}
          <p class="form__message form__message--success" tabindex="-1" autofocus>
            {{- 'customer.recover_password.success' | t -}}
          </p>
        {%- endif -%}
        {%- form 'customer_login' -%}
          <div class="field field--email login__field">
            <input
              type="email"
              name="customer[email]"
              class="field__input"
              id="CustomerEmail"
              dir="ltr"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              autofocus
              required
              {% if form.errors contains 'form' %}
                aria-invalid="true"
                aria-describedby="LoginForm-email-error"
              {% endif %}
              placeholder="{{ 'customer.login_page.email_placeholder' | t }}"
            >
            <label for="CustomerEmail" class="body-small">
              {{- 'customer.login_page.email' | t -}}
            </label>
            {% unless template.name == 'register' %}
              {{ form.errors | default_errors }}
            {% endunless %}
          </div>

          {%- if form.password_needed -%}
            <div class="field field--pass login__field">
              <div class="field--pass-wrapper">
                <div class="button-pass-visibility">
                  {% render 'icon-eye' %}
                  {% render 'icon-eye-close' %}
                </div>
                <input
                  type="password"
                  value=""
                  name="customer[password]"
                  class="field__input"
                  id="CustomerPassword"
                  dir="ltr"
                  autocomplete="current-password"
                  placeholder="{{ 'customer.login_page.password_placeholder' | t }}"
                  {% if form.errors contains 'form' %}
                    aria-invalid="true"
                  {% endif %}
                  required
                >
                <label for="CustomerPassword" class="body-small">
                  {{- 'customer.login_page.password' | t -}}
                </label>
              </div>

              {% unless template.name == 'register' %}
                {{ form.errors | default_errors }}
              {% endunless %}
            </div>
          {%- endif -%}

          <div class="login__buttons">
            <button type="submit" class="button button--primary login__sign-in focus-inset">
              <div class="button__content">
                <span class="button__label" data-label="{{- 'customer.log_in' | t -}}">
                  {{- 'customer.log_in' | t -}}
                </span>
              </div>
            </button>
            <a
              href="#recover"
              class="anchor button button--tertiary recover-link focus-inset"
            >
              <span>{{- 'customer.login_page.forgot_password' | t -}}</span>
            </a>
          </div>
        {%- endform -%}
      </div>

      <div class="login__form-info color-{{ section.settings.color_scheme_content_2 }} background">
        <div class="login__form-info-heading">
          <p class="body-normal">{{ 'customer.login_page.new_customer_title' | t }}</p>
          <span class="body-small">{{ 'customer.login_page.new_customer_text' | t }}</span>
        </div>
        {% assign register_btn_label = 'customer.login_page.create_account' | t %}
        {% render 'button',
          btn_label: register_btn_label,
          btn_style: 'transparent',
          btn_link: routes.account_register_url,
          class: 'login__to-register'
        %}
      </div>
    </div>

    {%- if shop.checkout.guest_login -%}
      <div class="login__guest">
        <div class="login__title h6">
          {{ 'customer.login_page.guest_title' | t }}
        </div>

        {%- form 'guest_login' -%}
          <button class="button button--primary focus-inset">
            <div class="button__content">
              <span class="button__label" data-label="{{- 'customer.login_page.guest_continue' | t -}}">
                {{- 'customer.login_page.guest_continue' | t -}}
              </span>
            </div>
          </button>
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>
  {% if section.settings.enable_background_image == true %}
    {% if section.settings.background_image != blank %}
      {% liquid
        assign image = section.settings.background_image

        assign image_styles = 'object-fit: cover;'
        assign calc_ratio_desktop = 1
        assign calc_ratio_mobile = 1

        assign desktop_aspect_ratio = 1.44
        assign mobile_aspect_ratio = 0.76
        if image.aspect_ratio > desktop_aspect_ratio
          assign calc_ratio_desktop = image.aspect_ratio | divided_by: desktop_aspect_ratio | round: 2
        endif

        if image.aspect_ratio > mobile_aspect_ratio
          assign calc_ratio_mobile = image.aspect_ratio | divided_by: desktop_aspect_ratio | round: 2
        endif

        assign image_loading = 'eager'
      %}

      {%- capture image_sizes -%}
      (min-width: 750px) calc(100vw * {{ calc_ratio_desktop }}), calc(100vw * {{ calc_ratio_mobile }})
    {%- endcapture -%}
      {{
        image
        | image_url: width: image.width
        | image_tag:
          width: image.width,
          height: image.height,
          widths: '360, 535, 600, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800',
          sizes: image_sizes,
          class: 'login__image',
          style: image_styles,
          loading: image_loading
      }}
    {% else %}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'login__image placeholder-svg' }}
    {% endif %}

    {% if section.settings.overlay_opacity != 0 %}
      <span
        class="login__overlay"
        style="opacity: {{ section.settings.overlay_opacity | times: 0.01 }};"
      ></span>
    {% endif %}
  {%- endif %}
</div>

<script>
  window.onload = () => {
    typeof PasswordViewer !== 'undefined' && new PasswordViewer();
  };
</script>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "tag": "section",
  "class": "login-section has-header-interaction",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme_content",
      "default": "background-1",
      "label": "t:sections.main-login.settings.color_scheme_content.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_content_2",
      "default": "background-2",
      "label": "t:sections.main-login.settings.color_scheme_content_2.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-login.settings.header_image.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_background",
      "default": "background-3",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "select",
      "id": "background_type",
      "options": [
        {
          "value": "adapt-to-content",
          "label": "t:sections.all.aspect_ratio.adapt_to_content.label"
        },
        {
          "value": "full_height",
          "label": "t:sections.all.aspect_ratio.full_height.label"
        }
      ],
      "default": "full_height",
      "label": "t:sections.main-login.settings.background_type.label"
    },
    {
      "type": "checkbox",
      "id": "enable_background_image",
      "label": "t:sections.all.background_image.label",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.all.background_image.label",
      "visible_if": "{{ section.settings.enable_background_image }}"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "unit": "%",
      "label": "t:sections.all.overlay_opacity.label",
      "visible_if": "{{ section.settings.enable_background_image }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ]
}
{% endschema %}
