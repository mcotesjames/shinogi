{{ 'section-image-gallery.css' | asset_url | stylesheet_tag }}

{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{% endstyle %}

<div class="image-gallery section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding{% if section.settings.enable_border_top %} section-border-top{% endif %}{% if section.settings.enable_border_bottom %} section-border-bottom{% endif %}">
  {% comment %} start heading group {% endcomment %}
  {% liquid
    assign has_section_top_button = false
    if section.settings.heading_group_button_show and section.settings.heading_group_button_label != blank
      assign has_section_top_button = true
    endif

    assign has_return_button = false
    if section.settings.show_return_button and section.settings.return_button_label != blank
      assign has_return_button = true
    endif
  %}
  {%- if section.settings.heading != blank
    or section.settings.description != blank
    or has_section_top_button
    or has_return_button
  -%}
    <div class="image-gallery__heading-group container heading-group{% if section.settings.heading_group_enable_border_bottom %} heading-group--border-bottom{% endif %}">
      {%- if has_return_button -%}
        <div class="image-gallery__return-btn-wrapper">
          {% render 'button',
            btn_label: section.settings.return_button_label,
            btn_link: section.settings.return_button_link,
            btn_style: 'tertiary',
            class: 'image-gallery__return-btn'
          %}
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank or section.settings.description != blank -%}
        <div class="heading-group__left">
          {%- if section.settings.heading != blank -%}
            <{{ section.settings.heading_tag | default: "h2" }}
              class="title {% if section.settings.heading_font == 'heading'%}{{ section.settings.heading_size }} size--{{ section.settings.heading_size }}{% else %}font--body{% endif %} richtext-link-inside"
            >
              {{- section.settings.heading -}}
            </{{ section.settings.heading_tag | default: "h2" }}>
          {%- endif -%}

          {%- if section.settings.description != blank -%}
            <div class="heading-group__description-wrapper">
              <div class="heading-group__description richtext-link-inside">
                {{- section.settings.description -}}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if has_section_top_button -%}
        <div class="heading-group__actions">
          {% render 'button',
            btn_label: section.settings.heading_group_button_label,
            btn_link: section.settings.heading_group_button_link,
            btn_style: section.settings.heading_group_button_style,
            class: 'heading-group__btn'
          %}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
  {% comment %} end heading group {% endcomment %}

  <div class="image-gallery__wrapper">
    <div class="image-gallery__grid count-{{ section.blocks.size }}" style="--count: {{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign image_loading = 'lazy'
          if section.index == 1 and forloop.index <= 5
            assign image_loading = 'eager'
          endif

          if section.settings.aspect_ratio == 'landscape'
            assign aspect_ratio = 1.5
          elsif section.settings.aspect_ratio == 'portrait'
            assign aspect_ratio = 0.8
          else
            assign aspect_ratio = 1
          endif

          assign calc_ratio = 1
          if block.settings.image.aspect_ratio > aspect_ratio
            assign calc_ratio = block.settings.image.aspect_ratio | divided_by: aspect_ratio | round: 2
          endif

          assign desktop_delimetr = 1
          if section.blocks.size > 1
            assign desktop_delimetr = 2
          endif
        -%}

        <div
          class="image-gallery__image"
          style="aspect-ratio: {{ aspect_ratio }};"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {%- capture image_sizes -%}
              (min-width: 750px) calc(100vw / {{ desktop_delimetr }}  * {{ calc_ratio }}), calc(100vw * {{ calc_ratio }})
            {%- endcapture -%}
            {{
              block.settings.image
              | image_url: width: 3840
              | image_tag:
                width: block.settings.image.width,
                height: block.settings.image.height,
                sizes: image_sizes,
                widths: '360, 420, 620, 840, 1240, 1500, 1920, 2560, 3000, 3840',
                loading: image_loading
            }}
          {%- else -%}
            {% assign image_index = forloop.index | modulo: 4 | plus: 1 %}
            {{ 'collection-apparel-' | append: image_index | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

