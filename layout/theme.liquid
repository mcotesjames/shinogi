<!doctype html>
<html
  class="no-js"
  lang="{{ request.locale.iso_code }}"
  data-scheme="{{ settings.color_scheme }}"
  dir="{% render '_page_direction' %}"
>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {% render '_favicon' %}

    {%- unless settings.type_header_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    <meta
      name="description"
      content="{% if page_description %}{{ page_description | escape }}{% else %}{{ shop.description | escape }}{% endif %}{% if current_page != 1 %} - Page {{ current_page }}{% endif %}"
    >

    {% render '_meta-tags' %}

    <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>

    {% comment %} DYNAMICALLY RETURNS ALL SCRIPTS REQUIRED BY SHOPIFY {% endcomment %}
    {{ content_for_header }}

    {% comment %} FONTS {% endcomment %}
    {% render '_fonts' %}

    {% comment %} DARK MODE VARIABLES {% endcomment %}
    {% render '_color-vars' %}

    {% comment %} BASIC VARIABLES AND STYLES {% endcomment %}
    {% render '_base-vars-styles' %}

    {% comment %} ACCOUNT COMPONENT VARIABLES {% endcomment %}
    {% render '_shopify-account-vars' %}

    {% comment %} SWIPER MIN CSS {% endcomment %}
    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

    {% comment %} BASIC STYLES {% endcomment %}
    {{ 'base.css' | asset_url | stylesheet_tag }}

    {% comment %} RICH TEXT (RTE) STYLES {% endcomment %}
    {{ 'component-rte.css' | asset_url | stylesheet_tag }}

    {% comment %} CART DRAWER & CART NOTIFICATION {% endcomment %}
    {%- if request.page_type != 'cart' -%}
      {%- if settings.enable_cart_drawer or settings.enable_cart_notification -%}
        {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
        {{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
        <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
        {%- if settings.show_shipping -%}
          {{ 'component-cart-shipping.css' | asset_url | stylesheet_tag }}
        {%- endif -%}
        {%- if settings.collection_empty_cart_drawer != blank -%}
          {{ 'component-collection-card.css' | asset_url | stylesheet_tag }}
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}

    {% comment %} PRODUCTS STYLES {% endcomment %}
    {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
    {%- if settings.quickview_show or settings.quickadd_show -%}
      {{- 'quick-view.css' | asset_url | stylesheet_tag -}}
      <script src="{{ 'quick-view.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {% comment %} FONTS PRELOAD {% endcomment %}
    {%- unless settings.type_body_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_body_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      {% comment %}theme-check-disable AssetPreload{% endcomment %}
      <link rel="preload" as="font" href="{{ settings.type_header_font | font_url }}" type="font/woff2" crossorigin>
      {% comment %}theme-check-enable AssetPreload{% endcomment %}
    {%- endunless -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>

    <script src="{{ 'popup.js' | asset_url }}" defer="defer"></script>

    {% if settings.show_back_to_top %}
      <script src="{{ 'scroll-top.js' | asset_url }}" defer="defer"></script>
    {% endif %}
  </head>

  <body class="template-{{ template.name }} template-{{ template | replace: '.', '-' }}">
    <a class="skip-to-content-link visually-hidden" href="#MainContent">
      {{- 'accessibility.skip_to_text' | t -}}
    </a>

    {% sections 'header-group' %}

    {% sections 'overlay-group' %}

    {%- if settings.show_breadcrumbs -%}
      {% assign template_base = template | split: '.' | first %}
      {%- unless template_base == 'index' or template_base == 'product' or template_base == 'article' -%}
        {% render 'breadcrumbs', class: 'base-breadcrumbs' %}
      {%- endunless -%}
    {%- endif -%}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- if settings.show_back_to_top -%}
      {% render 'scroll-top' %}
    {%- endif -%}

    {%- if request.page_type != 'cart' and settings.enable_cart_drawer -%}
      {%- render 'cart-drawer' -%}
    {%- endif -%}

    {%- if request.page_type != 'cart' and settings.enable_cart_notification -%}
      {%- render 'cart-notification' -%}
    {%- endif -%}

    <ul hidden>
      <li id="a11y-refresh-page-message">
        {{- 'accessibility.refresh_page' | t -}}
      </li>
    </ul>

    {% render '_support_scripts' %}
  </body>
</html>
