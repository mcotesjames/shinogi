{% doc %}
  Renders a cart item.

  @param {object} item - Special object containing the cart item.
  @param {string} cart_type - A cart type ('cart-page' or 'cart-drawer' or 'cart-notification').

  @example
  {% render 'cart-item', item: item %}
{% enddoc %}

{%- liquid
  assign item_id = blank
  assign item_index = item.index | plus: 1
  assign item_suffix = item_index
  case cart_type
    when 'cart-page'
      assign item_id = 'CartItem-' | append: item_index
    when 'cart-drawer'
      assign item_id = 'CartDrawer-Item-' | append: item_index
    when 'cart-notification'
      assign item_id = 'CartNotification-Item-' | append: item.key
      assign item_suffix = 'Notification-' | append: item_index
  endcase
-%}

<div id="{{ item_id }}" class="cart-item" data-index="{{ item_index }}">
  <div class="cart-item__inner">
    {% liquid
      case settings.card_media_ratio
        when 'landscape'
          assign ratio = '4/3'
          assign settings_aspect_ratio = 1.33
        when 'portrait'
          assign ratio = '94/124'
          assign settings_aspect_ratio = 0.758
        when 'square'
          assign ratio = '1/1'
          assign settings_aspect_ratio = 1
      endcase

      assign aspect_ratio = ratio | split: '/'
      assign temp = aspect_ratio[0] | append: '.0'
      assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
    %}
    <div class="cart-item__left">
      <div
        class="cart-item__media{% if item.image == blank %} cart-item__media--placeholder{% endif %}"
        style="padding-bottom: {{ padding_bottom }}%"
      >
        <a
          href="{{ item.url }}"
          class="cart-item__link focus-inset"
          aria-label="{{ 'accessibility.product_link' | t }}"
        ></a>
        {%- if item.image -%}
          {% liquid
            assign calc_ratio = 1
            if settings.card_media_fit == 'cover' and item.image.aspect_ratio > settings_aspect_ratio
              assign calc_ratio = item.image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
            endif
          %}
          {%- capture img_sizes -%}
            (min-width: 576px) calc({{ calc_ratio }} * 94px), calc({{ calc_ratio }} * 80px)
          {%- endcapture -%}
          {%- capture image_styles -%}
            object-fit: {{ settings.card_media_fit }};
          {%- endcapture -%}
          {{
            item.image
            | image_url: width: item.image.width
            | image_tag:
              loading: 'lazy',
              widths: '94, 188, 282, 376, 640, 750, 990, 1200, 1500, 1800, 2000',
              sizes: img_sizes,
              class: 'cart-item__image',
              style: image_styles
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg cart-item__image' }}
        {%- endif -%}
      </div>
    </div>

    <div class="cart-item__details">
      <div class="cart-item__details-wrapper">
        <div class="cart-item__info">
          <div class="cart-item__column">
            {%- if settings.show_vendor -%}
              <div class="cart-item__vendor subtitle subtitle--small">
                {%- if settings.enable_vendor_link -%}
                  {{- item.product.vendor | link_to_vendor: class: 'focus-inset' -}}
                {%- else %}
                  {{- item.product.vendor -}}
                {%- endif -%}
              </div>
            {%- endif -%}

            <a href="{{ item.url }}" class="cart-item__name focus-inset" aria-label="{{ item.product.title | escape }}">
              <span>{{ item.product.title | escape }}</span>
            </a>

            {%- if item.product.has_only_default_variant == false -%}
              {%- assign options_arr = item.options_with_values | map: 'name' -%}
              {%- assign values_arr = item.options_with_values | map: 'value' -%}
              <dl class="product-options body-small">
                <dt class="visually-hidden">{{ options_arr | join: ' / ' }}</dt>
                <dd>{{ values_arr | join: ' / ' }}</dd>
              </dl>
            {%- endif -%}

            {%- for property in item.properties -%}
              {%- assign property_first_char = property.first | slice: 0 -%}
              {%- if property.last != blank and property_first_char != '_' -%}
                <dl class="product-property body-small">
                  <dt>{{ property.first }}:</dt>
                  <dd>
                    {%- if property.last contains '/uploads/' -%}
                      <a
                        href="{{ property.last }}"
                        class="hover-underlined-link-secondary"
                        target="_blank"
                      >
                        {{- property.last | split: '/' | last -}}
                      </a>
                    {%- else -%}
                      {{- property.last -}}
                    {%- endif -%}
                  </dd>
                </dl>
              {%- endif -%}
            {%- endfor -%}

            {%- if item.selling_plan_allocation != null -%}
              <p class="product-property body-small">
                {{ item.selling_plan_allocation.selling_plan.name }}
              </p>
            {% endif %}

            {%- if item.line_level_discount_allocations.size != 0 -%}
              <ul
                class="discounts list-unstyled"
                role="list"
                aria-label="{{ 'customer.order.discount' | t }}"
              >
                {%- for discount in item.line_level_discount_allocations -%}
                  {% liquid
                    if settings.currency_code_enabled
                      assign discount_total = discount.discount_application.total_allocated_amount | money_with_currency
                    else
                      assign discount_total = discount.discount_application.total_allocated_amount | money
                    endif
                  %}
                  <li class="discounts__discount body-small">
                    {%- render 'icon-discount' -%}
                    {{ discount.discount_application.title }}
                    (- {{ discount_total }})
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
            {%- if item.variant.available and item.unit_price_measurement -%}
              <div class="unit-price">
                <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                {{- item.variant.unit_price | unit_price_with_measurement: item.variant.unit_price_measurement -}}
              </div>
            {%- endif -%}
          </div>
          <div
            id="Line-item-error-{{ item_suffix }}"
            class="cart-item__error"
            role="alert"
          >
            <small class="cart-item__error-text"></small>
            {% render 'icon-error' %}
          </div>
          <div class="cart-item__quantity-wrapper">
            <label class="visually-hidden" for="Quantity-{{ item_index }}">
              {{- 'products.product.quantity.label' | t -}}
            </label>
            <quantity-input class="quantity">
              <button
                class="quantity__button no-js-hidden focus-inset"
                name="minus"
                type="button"
              >
                <span class="visually-hidden">
                  {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                </span>
                {% render 'icon-minus' %}
              </button>
              <input
                class="quantity__input focus-inset"
                type="number"
                name="updates[]"
                value="{{ item.quantity }}"
                min="0"
                aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                id="Quantity-{{ item_suffix }}"
                data-index="{{ item_index }}"
              >
              <button
                class="quantity__button no-js-hidden focus-inset"
                name="plus"
                type="button"
              >
                <span class="visually-hidden">
                  {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                </span>
                {% render 'icon-plus' %}
              </button>
            </quantity-input>
          </div>
        </div>
      </div>

      <div class="cart-item__right">
        <cart-remove-button
          id="Remove-{{ item_suffix }}"
          data-index="{{ item_index }}"
        >
          <button
            type="button"
            class="button button--simple focus-inset"
            aria-label="{{ 'general.cart.remove_product' | t: title: item.title }}"
          >
            <span class="button__label desktop" data-label="{{ 'general.cart.remove_button_label' | t }}">
              {{- 'general.cart.remove_button_label' | t -}}
            </span>
            <span class="button__label mobile">{% render 'icon-remove' %}</span>
          </button>
        </cart-remove-button>
        <div class="cart-item__right-price">
          <dl class="cart-item__price-wrapper">
            {%- if item.original_line_price != item.final_line_price -%}
              <dt class="visually-hidden">
                {{- 'products.product.price.sale_price' | t -}}
              </dt>
              <dd class="cart-item__final-price cart-item__final-price_sale">
                {%- if settings.currency_code_enabled -%}
                  {{- item.final_line_price | money_with_currency -}}
                {%- else -%}
                  {{- item.final_line_price | money -}}
                {%- endif -%}
              </dd>
              <dt class="visually-hidden">
                {{- 'products.product.price.regular_price' | t -}}
              </dt>
              <dd>
                <s class="cart-item__old-price">
                  {%- if settings.currency_code_enabled -%}
                    {{- item.original_line_price | money_with_currency -}}
                  {%- else -%}
                    {{- item.original_line_price | money -}}
                  {%- endif -%}
                </s>
              </dd>
            {%- else -%}
              <dt class="visually-hidden">
                {{ 'products.product.price.regular_price' | t }}
              </dt>
              <dd class="cart-item__final-price">
                {%- if settings.currency_code_enabled -%}
                  {{- item.original_line_price | money_with_currency -}}
                {%- else -%}
                  {{- item.original_line_price | money -}}
                {%- endif -%}
              </dd>
            {%- endif -%}
          </dl>
        </div>
      </div>
    </div>
  </div>

  <div class="loading-overlay hidden">
    <div class="loading-overlay__spinner">
      {% render 'icon-loading' %}
    </div>
  </div>
</div>
