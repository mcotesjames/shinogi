{% doc %}
  Renders product specification groups from metafields.

  @param {object} product - Product Liquid object
  @param {object} block_obj - Block Liquid object

  @example
  {% render 'product-block-specification', product: product, block_obj: block %}
{% enddoc %}

{%- liquid
  assign specification_groups = blank
  if product.metafields.custom.specification != blank
    assign specification_groups = product.metafields.custom.specification.value
  endif

  assign has_specifications = false
  if specification_groups != blank
    assign has_specifications = true
  endif

  assign specification_default_open = false
  if block_obj != blank and block_obj.settings.default_open
    assign specification_default_open = true
  endif

  assign block_attributes = ''
  if block_obj != blank
    assign block_attributes = block_obj.shopify_attributes
  endif
-%}

{%- if product.metafields.custom.specification != blank -%}
  <!-- debug: product.metafields.custom.specification exists -->
{%- else -%}
  <!-- debug: product.metafields.custom.specification is blank or missing -->
{%- endif -%}

{%- if has_specifications -%}
  <!-- debug: specification_groups count={{ specification_groups.size | default: 0 }} -->
  {%- for specification_group in specification_groups -%}
    <!-- debug: group index={{ forloop.index }} title={{ specification_group.specification_title | default: '[blank]' }} -->
    {%- if specification_group.specification_title != blank -%}
      {%- assign group_default_open = false -%}
      {%- if specification_default_open and forloop.first -%}
        {%- assign group_default_open = true -%}
      {%- endif -%}
      <div class="product-accordion" {{ block_attributes }}>
        <button
          class="button button--simple product-accordion__toggle{% if group_default_open %} active{% endif %} focus-inset"
          aria-label="{{ specification_group.specification_title | escape }}"
        >
          <div class="button__content">
            <span class="button__label" data-label="{{- specification_group.specification_title | escape -}}">
              {{- specification_group.specification_title | escape -}}
            </span>

            <div class="product-accordion__icon">
              {% render 'icon-plus-dropdown' %}
              {% render 'icon-minus-dropdown' %}
            </div>
          </div>
        </button>

        <div class="product-accordion__content{% if group_default_open %} active{% endif %}">
          {%- if specification_group.specification_item.value != blank or specification_group.specification_headings.value != blank -%}
            {%- if specification_group.specification_headings.value != blank -%}
              <!-- debug: group headings count={{ specification_group.specification_headings.value.size | default: 0 }} -->
            {%- endif -%}
            <!-- debug: group items count={{ specification_group.specification_item.value.size | default: 0 }} -->
            <div class="product-accordion__specification-items">
              {%- if specification_group.specification_headings.value != blank -%}
                {%- for specification_heading in specification_group.specification_headings.value -%}
                  <!-- debug: heading index={{ forloop.index }} value={{ specification_heading | default: '[blank]' }} -->
                  <div class="product-accordion__specification-item product-accordion__specification-item--heading">
                    <div class="product-accordion__specification-cell product-accordion__specification-cell--heading specifications__detail-title subtitle">
                      {{- specification_heading -}}
                    </div>
                  </div>
                {%- endfor -%}
              {%- endif -%}
              {%- if specification_group.specification.value != blank -%}
                {%- for specification_item in specification_group.specification.value -%}
                  <!-- debug: item index={{ forloop.index }} col1={{ specification_item.column_1 | default: '[blank]' }} col2={{ specification_item.column_2 | default: '[blank]' }} col3={{ specification_item.column_3 | default: '[blank]' }} col4={{ specification_item.column_4 | default: '[blank]' }} -->
                  <div class="product-accordion__specification-item">
                    {%- if specification_item.column_1 != blank -%}
                      <div class="product-accordion__specification-cell specifications__detail-title subtitle">
                        {{- specification_item.column_1 -}}
                      </div>
                    {%- endif -%}
                    {%- if specification_item.column_2 != blank -%}
                      <div class="product-accordion__specification-cell specifications__detail-title subtitle">
                        {{- specification_item.column_2 -}}
                      </div>
                    {%- endif -%}
                    {%- if specification_item.column_3 != blank -%}
                      <div class="product-accordion__specification-cell specifications__detail-title subtitle">
                        {{- specification_item.column_3 -}}
                      </div>
                    {%- endif -%}
                    {%- if specification_item.column_4 != blank -%}
                      <div class="product-accordion__specification-cell specifications__detail-title subtitle">
                        {{- specification_item.column_4 -}}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              {%- endif -%}
            </div>
          {%- else -%}
            <!-- debug: specification_group.specification_item.value and specification_group.specification_headings.value are blank -->
          {%- endif -%}
        </div>
      </div>
    {%- else -%}
      <!-- debug: specification_group.specification_title is blank -->
    {%- endif -%}
  {%- endfor -%}
{%- else -%}
  <!-- debug: specification_groups is blank -->
{%- endif -%}
