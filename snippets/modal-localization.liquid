{% liquid
  assign form_id = 'HeaderCountryForm'
  if modal_location == 'footer'
    assign form_id = 'FooterCountryForm'
  endif
  if modal_location == 'header_mobile'
    assign form_id = 'HeaderMobileCountryForm'
  endif

  assign list_id = 'HeaderCountryList'
  if modal_location == 'footer'
    assign list_id = 'FooterCountryList'
  endif
  if modal_location == 'header_mobile'
    assign list_id = 'HeaderMobileCountryList'
  endif
%}

<modal-localization-form class="modal-country-form">
  {%- form 'localization', id: form_id, class: 'localization-form' -%}
    <div class="no-js-hidden">
      <div class="disclosure">
        <button
          type="button"
          class="modal-localization-button localization-selector focus-inset"
          aria-expanded="false"
          aria-controls="{{ list_id }}"
        >
          <div>
            <span class="form-active-placeholder-text">{{ 'localization.country_label' | t }}</span>
            <span class="localization-value-label form-text">
              {{ localization.country.name }} (
              {{- localization.country.currency.iso_code }}
              {{ localization.country.currency.symbol -}}
              )
            </span>
          </div>

          {% render 'icon-caret' %}
        </button>
        <ul
          id="{{ list_id }}"
          role="list"
          class="disclosure__list list-unstyled color-background-1"
          hidden
        >
          {%- for country in localization.available_countries -%}
            <li class="disclosure__item" tabindex="-1">
              <a
                class="disclosure__link {% if country.iso_code == localization.country.iso_code %} disclosure__link--active{% endif %} focus-inset"
                href="#"
                {% if country.iso_code == localization.country.iso_code %}
                  aria-current="true"
                {% endif %}
                data-value="{{ country.iso_code }}"
                data-label="{{ country.name }} ({{- country.currency.iso_code }} {{ country.currency.symbol -}})"
              >
                <span class="form-text">
                  {{ country.name }}
                  <span class="localization-form__currency">
                    (
                    {{- country.currency.iso_code }}
                    {{ country.currency.symbol -}}
                    )
                  </span>
                </span>

                {% render 'icon-check' %}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
      <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
      <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
    </div>
  {%- endform -%}
</modal-localization-form>
