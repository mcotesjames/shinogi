<style>
  @media screen and (min-width: 750px) {
    {% if section.settings.cart_button_type == "icon" -%}
      .cart-count-bubble {
        width: 2rem;
        height: 2rem;
        position: relative;
        overflow: visible;
      }
      .cart-count-bubble__icon {
        display: block;
      }
      .cart-count-bubble__text {
        display: none;
      }
      .cart-count-bubble__count {
        position: absolute;
        top: 1.1rem;
        right: -0.7rem;
        color: rgb(var(--color-background));
        background-color: rgb(var(--color-foreground));
        padding: 0.1rem 0.36rem;
        min-width: 1.2rem;
        height: 1.6rem;
      }
    {% elsif section.settings.cart_button_type == "texticon" -%}
      .header__cart {
        width: unset;
      }
      .cart-count-bubble__icon {
        display: block;
      }
      .cart-count-bubble__text {
        display: flex;
      }
    {% else -%}
      .header__cart {
        width: unset;
      }
      .cart-count-bubble__icon {
        display: none;
      }
      .cart-count-bubble__text {
        display: flex;
      }
    {%- endif %}
  }
  @media screen and (max-width: 749.99px) {
    {% if section.settings.cart_button_type_mobile == "icon" -%}
      .cart-count-bubble {
        width: 2rem;
        height: 2rem;
        position: relative;
        overflow: visible;
      }
      .cart-count-bubble__icon {
        display: block;
      }
      .cart-count-bubble__text {
        display: none;
      }
      .cart-count-bubble__count {
        position: absolute;
        top: 1.1rem;
        right: -0.7rem;
        color: rgb(var(--color-background));
        background-color: rgb(var(--color-foreground));
        padding: 0.1rem 0.36rem;
        min-width: 1.2rem;
        height: 1.6rem;
      }
    {% elsif section.settings.cart_button_type_mobile == "texticon" -%}
      .header__cart {
        width: unset;
      }
      .cart-count-bubble__icon {
        display: block;
      }
      .cart-count-bubble__text {
        display: flex;
      }
    {% else -%}
      .header__cart {
        width: unset;
      }
      .cart-count-bubble__icon {
        display: none;
      }
      .cart-count-bubble__text {
        display: flex;
      }
    {%- endif %}
  }
</style>
