{% doc %}
  Renders a product media item.

  @param {object} product_obj - Product object
  @param {object} section_obj - Section object
  @param {object} [media] - Media object
  @param {boolean} [is_featured] - Flag for featured media
  @param {boolean} [is_featured_product_placeholder] - Flag for featured product section placeholder
  @param {number} [featured_product_placeholder_index] - Featured product section placeholder number

  @example
  {% render 'product-media-item', block_obj: block %}
{% enddoc %}

{%- liquid
  assign desktop_media_ratio = section_obj.settings.desktop_media_ratio | default: 'portrait'
  assign mobile_media_ratio = section_obj.settings.mobile_media_ratio | default: 'portrait'
  assign media_fit = section_obj.settings.image_fit | default: 'cover'
  assign is_video_loop = section_obj.settings.enable_video_looping
  assign is_video_autoplay = section_obj.settings.enable_video_autoplay
  assign zoom_modal_id = section_obj.id
  assign enable_image_zoom_mobile = section_obj.settings.enable_image_zoom_mobile
  assign enable_image_zoom_desktop = section_obj.settings.enable_image_zoom_desktop
  assign has_zoom_modal = false
  if enable_image_zoom_mobile or enable_image_zoom_desktop
    assign has_zoom_modal = true
  endif

  case desktop_media_ratio
    when 'landscape'
      # 4:3
      assign settings_aspect_ratio = 1.33
      assign main_image_style = 'padding-bottom: 75%;'
    when 'portrait'
      # 668:880
      assign settings_aspect_ratio = 0.76
      assign main_image_style = 'padding-bottom: 131.7%;'
    when 'square'
      # 1:1
      assign settings_aspect_ratio = 1
      assign main_image_style = 'padding-bottom: 100%;'
    when 'full_height'
      # full screen height
      assign settings_aspect_ratio = 0.75
      assign main_image_style = 'height: calc(100vh - var(--announcement-height) - var(--header-height));'
  endcase

  case mobile_media_ratio
    when 'landscape'
      # 4:3
      assign settings_aspect_ratio_mobile = 1.33
    when 'portrait'
      # 3:4
      assign settings_aspect_ratio_mobile = 0.75
    when 'square'
      # 1:1
      assign settings_aspect_ratio_mobile = 1
  endcase
-%}

{%- if media != blank -%}
  {%- liquid
    assign img_alt = product_obj.title | append: '-' | append: media.position
    if media.preview_image.alt != blank
      assign img_alt = media.preview_image.alt
    endif

    assign desktop_calc_ratio = 1
    if media_fit == 'cover' and media.aspect_ratio > settings_aspect_ratio
      assign desktop_calc_ratio = media.preview_image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
    endif
    assign mobile_calc_ratio = 1
    if media_fit == 'cover' and media.aspect_ratio > settings_aspect_ratio_mobile
      assign mobile_calc_ratio = media.preview_image.aspect_ratio | divided_by: settings_aspect_ratio_mobile | round: 2
    endif
    assign widths = '360, 535, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000, 2200, 2400, 2600, 2800, 3000, 3200, 3400, 3600, 3800'

    assign fetch_priority = 'auto'
    assign loading = 'lazy'
    if section_obj.index == 1 and media.position == 1
      assign fetch_priority = 'high'
      assign loading = 'eager'
    endif
  -%}

  {%- capture img_sizes -%}
    (min-width: 1200px) calc(70vw * {{ desktop_calc_ratio }}), (min-width: 990px) calc(70vw * {{ desktop_calc_ratio }}), calc(100vw * {{ mobile_calc_ratio }})
  {%- endcapture -%}

  {%- capture img_style -%}
    object-fit: {{ media_fit }};
  {%- endcapture -%}

  {% liquid
    assign modal_opener_tag = 'div'
    if has_zoom_modal
      assign modal_opener_tag = 'modal-opener'
    endif
  %}
  <{{ modal_opener_tag }}
    class="product__modal-opener product__modal-opener--{{ media.media_type }}"
    {% if has_zoom_modal -%}
      data-modal="#ProductModal-{{ zoom_modal_id }}"
    {%- endif %}
  >
    <div
      class="product__media-img product__media-img--mobile-ratio-{{ mobile_media_ratio }}"
      style="{{ main_image_style }}"
    >
      {{
        media.preview_image
        | image_url: width: media.preview_image.width
        | image_tag:
          loading: loading,
          fetchpriority: fetch_priority,
          widths: widths,
          sizes: img_sizes,
          style: img_style,
          alt: img_alt
      }}
    </div>

    {%- if has_zoom_modal and media.media_type == 'image' -%}
      <button
        class="product__media-toggle{% if enable_image_zoom_mobile != true %} product__media-toggle--disabled-on-mobile{% endif %}{% if enable_image_zoom_desktop != true %} product__media-toggle--disabled-on-desktop{% endif %} no-js-hidden"
        type="button"
        aria-haspopup="dialog"
        data-media-id="{{ media.id }}"
      >
        <span class="visually-hidden">
          {%- if is_featured == true %}
            {{ 'products.product.media.open_featured_media' | t }}
          {%- else -%}
            {{ 'products.product.media.open_media' | t: index: media.position }}
          {%- endif -%}
        </span>
      </button>

      <span
        class="product__media-mobile-icon motion-reduce{% if enable_image_zoom_mobile != true %} product__media-mobile-icon--disabled-on-mobile{% endif %} no-js-hidden"
        aria-hidden="true"
      >
        {% render 'icon-plus-zoom' %}
      </span>
    {%- endif -%}
  </{{ modal_opener_tag }}>

  {%- if media.media_type != 'image' -%}
    {%- if media.media_type == 'model' -%}
      <product-model class="deferred-media no-js-hidden" data-media-id="{{ media.id }}">
    {%- else -%}
      <deferred-media
        class="deferred-media no-js-hidden"
        data-media-id="{{ media.id }}"
        data-autoplay="{{ is_video_autoplay }}"
      >
    {%- endif -%}
    <button id="Deferred-Poster-Modal-{{ media.id }}" class="deferred-media__poster focus-inset" type="button">
      <span class="deferred-media__poster-button motion-reduce">
        {%- if media.media_type == 'model' -%}
          <span class="visually-hidden">{{ 'products.product.media.play_model' | t }}</span>
          {%- render 'icon-3d-model' -%}
        {%- else -%}
          <span class="visually-hidden">{{ 'products.product.media.play_video' | t }}</span>
          {%- render 'icon-play' -%}
        {%- endif -%}
      </span>
      {{
        media.preview_image
        | image_url: width: media.preview_image.width
        | image_tag:
          loading: loading,
          fetchpriority: fetch_priority,
          widths: widths,
          sizes: img_sizes,
          style: img_style,
          alt: img_alt
      }}
    </button>
    <template>
      {%- case media.media_type -%}
        {%- when 'external_video' -%}
          {%- assign video_class = 'js-' | append: media.host -%}
          {%- if media.host == 'youtube' -%}
            {{
              media
              | external_video_url:
                autoplay: true,
                loop: is_video_loop,
                playlist: media.external_id,
                mute: is_video_autoplay
              | external_video_tag: class: video_class, loading: loading
            }}
          {%- else -%}
            {{
              media
              | external_video_url: autoplay: true, loop: is_video_loop, muted: is_video_autoplay
              | external_video_tag: class: video_class, loading: loading
            }}
          {%- endif -%}
        {%- when 'video' -%}
          {{
            media
            | media_tag:
              image_size: '2048x',
              autoplay: true,
              loop: is_video_loop,
              controls: true,
              preload: 'none',
              muted: is_video_autoplay
          }}
        {%- when 'model' -%}
          {{ media | media_tag: image_size: '2048x', toggleable: true }}
      {%- endcase -%}
    </template>

    {%- if media.media_type == 'model' -%}
      </product-model>
      <button
        class="button product__xr-button button--simple focus-inset"
        type="button"
        aria-label="{{ 'products.product.xr_button_label' | t }}"
        data-shopify-xr
        data-shopify-model3d-id="{{ media.id }}"
        data-shopify-title="title"
        data-shopify-xr-hidden
      >
        {% render 'icon-3d-model' %}
        {{ 'products.product.xr_button' | t }}
      </button>
    {%- else -%}
      </deferred-media>
    {%- endif -%}
  {%- endif -%}
{%- else -%}
  <div
    class="product__media-img product__media-img--mobile-ratio-{{ mobile_media_ratio }}"
    style="{{ main_image_style }}"
  >
    {%- if is_featured_product_placeholder != true -%}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- else -%}
      {{ 'product-apparel-' | append: featured_product_placeholder_index | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>
{%- endif -%}
