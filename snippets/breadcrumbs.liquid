<div class="{% if without_container %}{% else %}container{% endif %}{% if class %} {{ class }}{% endif %}">
  <nav
    id="breadcrumbs"
    class="breadcrumb subtitle"
    role="navigation"
    aria-label="breadcrumbs"
    {% if without_paddings -%}
      style="padding: 0;"
    {%- endif %}
  >
    <a href="{{ routes.root_url }}" title="{{ 'general.breadcrumbs.home' | t }}" class="focus-inset">
      {{- 'general.breadcrumbs.home' | t -}}
    </a>
    {% if template contains 'page' %}
      <div class="breadcrumb__delimiter"></div>
      <span>{{ page.title }}</span>
    {% elsif template == 'cart' %}
      <div class="breadcrumb__delimiter"></div>
      <span>{{ 'general.breadcrumbs.cart' | t }}</span>
    {% elsif template == 'article' %}
      <div class="breadcrumb__delimiter"></div>
      <a href="{{ blog.url }}" class="focus-inset">{{ blog.title }}</a>
      <div class="breadcrumb__delimiter"></div>
      <span>{{ page_title }}</span>
    {% elsif template contains 'product' %}
      <div class="breadcrumb__delimiter"></div>
      {% assign first_collection = product.collections | first %}
      {% if first_collection != blank %}
        <a href="{{ first_collection.url }}" class="focus-inset">{{- first_collection.title -}}</a>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}">{{- 'general.breadcrumbs.shop' | t -}}</a>
      {% endif %}
      <div class="breadcrumb__delimiter"></div>
      <span>{{ product.title }} </span>
    {% elsif template == 'blog' %}
      <div class="breadcrumb__delimiter"></div>
      {% if current_tags %}
        {{ blog.title | link_to: blog.url }}
        <div class="breadcrumb__delimiter"></div>
        <span>{{ current_tags | join: ' + ' }} </span>
      {% else %}
        <span>{{ blog.title }}</span>
      {% endif %}
    {% elsif template == 'customers/order' %}
      <div class="breadcrumb__delimiter"></div>
      <a href="{{ routes.account_url }}" class="focus-inset">{{- 'general.breadcrumbs.account' | t -}}</a>
      <div class="breadcrumb__delimiter"></div>
      <span>
        {{- 'general.breadcrumbs.order' | t }}
        {{ order.name }}
      </span>
    {% elsif template == 'customers/addresses' %}
      <div class="breadcrumb__delimiter"></div>
      <a href="{{ routes.account_url }}" class="focus-inset">{{- 'general.breadcrumbs.account' | t -}}</a>
      <div class="breadcrumb__delimiter"></div>
      <span>{{ 'general.breadcrumbs.addresses' | t }} </span>
    {% elsif template == 'search' %}
      <div class="breadcrumb__delimiter"></div>
      {% if search.performed %}
        <span>{{ 'general.breadcrumbs.search_results' | t }} </span>
      {% else %}
        <span>{{ page_title }} </span>
      {% endif %}
    {% else %}
      <div class="breadcrumb__delimiter"></div>
      <span>{{ page_title }} </span>
    {% endif %}
  </nav>

  <script>
    (function () {
      const calcBreadcrumbs = () => {
        const breadcrumbs = document.querySelector('.breadcrumb');
        if (breadcrumbs) {
          const breadcrumbsObserver = new ResizeObserver((entries) => {
            entries.forEach((entry) => {
              const breadcrumbsHeight = breadcrumbs.getBoundingClientRect().height.toFixed(2);
              document.documentElement.style.setProperty('--breadcrumbs-height', `${breadcrumbsHeight}px`);
            });
          });
          breadcrumbsObserver.observe(breadcrumbs);
        }
      };
      calcBreadcrumbs();

      document.addEventListener('shopify:section:load', function () {
        calcBreadcrumbs();
      });
    })();
  </script>
</div>
