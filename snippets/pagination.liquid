{% comment %}
  Renders a set of links for paginated results. Must be used within paginate tags.

  Usage:
  {% paginate results by 2 %}
    {% render 'pagination', paginate: paginate, anchor: '#yourID' %}
  {% endpaginate %}

  Accepts:
  - paginate: {Object}
  - anchor: {String} (optional) This can be added so that on page reload it takes you to wherever you've placed your anchor tag.
  - class: {String} (optional) Appended to container element's class attribute
{% endcomment %}

{{ 'component-pagination.css' | asset_url | stylesheet_tag }}

{%- if paginate.parts.size > 0 -%}
  <div class="{{ class | default: 'pagination-wrapper' }} pagination-block no-js-block">
    <nav class="pagination container" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
      <ul class="pagination__list list-unstyled" role="list">
        {%- if paginate.previous -%}
          <li>
            <a
              href="{{ paginate.previous.url }}{{ anchor }}"
              class="pagination__item-toggler pagination__item-toggler--prev button button--tertiary"
              aria-label="{{ 'general.pagination.previous' | t }}"
            >
              <span>{{ 'general.pagination.previous' | t | strip_newlines }}</span>
            </a>
          </li>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          <li>
            {%- if part.is_link -%}
              <a
                href="{{ part.url }}{{ anchor }}"
                class="pagination__item"
                aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
              >
                <span class="body-small" title="{{ part.title }}"> {{ part.title }}</span>
              </a>
            {%- else -%}
              {%- if part.title == paginate.current_page -%}
                <span
                  class="pagination__item pagination__item--current body-small"
                  aria-current="page"
                  aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
                >
                  {{- part.title -}}
                </span>
              {%- else -%}
                <span class="pagination__item body-small">{{ part.title }}</span>
              {%- endif -%}
            {%- endif -%}
          </li>
        {%- endfor -%}

        {%- if paginate.next -%}
          <li>
            <a
              href="{{ paginate.next.url }}{{ anchor }}"
              class="pagination__item-toggler pagination__item-toggler--next button button--tertiary"
              aria-label="{{ 'general.pagination.next' | t }}"
            >
              <span>{{ 'general.pagination.next' | t | strip_newlines }}</span>
            </a>
          </li>
        {%- endif -%}
      </ul>
    </nav>
  </div>
{%- endif -%}
